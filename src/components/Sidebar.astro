---
import Icon from './Icon.astro';
import AdSense from './AdSense.astro';

const maisLidos = [
  { category: 'Games', title: 'Palia: Royal Highlands. Como se preparar para a nova expansão', link: '#' },
  { category: 'IA', title: 'Como o DeepSeek R1 redefiniu o custo de modelos de raciocínio', link: '#' },
  { category: 'Games', title: 'Melhores jogos curtos do Xbox Game Pass em 2026 para zerar', link: '#' },
  { category: 'Web Design', title: 'Por que o CSS Nesting nativo mudou nossa estrutura de escopos', link: '#' },
  { category: 'Programação', title: 'Aprenda a estruturar rotas dinâmicas no novo Astro v7', link: '#' },
  { category: 'Games', title: 'Calendário de lançamentos de games 2026 no Brasil', link: '#' },
  { category: 'Games', title: 'PS Plus de Abril: quais jogos baixar primeiro em seu console', link: '#' },
  { category: 'Tecnologia', title: 'Vale comprar o Switch 2 se você já tem a versão OLED?', link: '#' },
  { category: 'Games', title: 'Xbox Game Pass em Abril: ordem recomendada para jogar os títulos', link: '#' },
  { category: 'Web Design', title: 'Como planejar wireframes focados em conversão de cliques', link: '#' },
];
---

<div class="lg:col-span-1 space-y-10 font-sans">
  <!-- Widget Mais Lidos -->
  <div class="bg-white dark:bg-darkbg-900 rounded-xl p-6 border border-slate-200/50 dark:border-slate-800/50 shadow-sm">
    <div class="flex items-center justify-between border-b border-slate-100 dark:border-zinc-800 pb-4 mb-4">
      <h3 class="font-display font-extrabold text-lg text-slate-900 dark:text-white flex items-center gap-2">
        <Icon name="flame" class="text-orange-500 w-4 h-4" /> Mais Lidos
      </h3>
    </div>

    <div class="divide-y divide-slate-100 dark:divide-zinc-800/80">
      {maisLidos.map((item, index) => (
        <article class="group py-3 flex gap-4 items-start relative">
          <a href={item.link} class="absolute inset-0 z-20" aria-label={item.title}></a>
          <div class="font-display font-black text-2xl text-slate-400 dark:text-zinc-500 tracking-tight shrink-0 transition-colors group-hover:text-brand-600/40 w-8">
            {String(index + 1).padStart(2, '0')}
          </div>
          <div>
            <span class="text-[9px] font-extrabold tracking-widest text-brand-600 uppercase font-display">{item.category}</span>
            <h5 class="font-display font-bold text-xs text-slate-800 dark:text-zinc-200 group-hover:text-brand-600 dark:group-hover:text-brand-500 transition-colors mt-0.5 leading-snug">
              {item.title}
            </h5>
          </div>
        </article>
      ))}
    </div>
  </div>

  <!-- AdSense Sidebar Rectangle -->
  <AdSense 
    slot="5678901234" 
    simulatedText="Google AdSense - Retângulo Médio Lateral (300x250)" 
    style="display:inline-block;width:300px;height:250px"
    class="flex flex-col items-center justify-center min-h-[300px]"
  />

  <!-- Widget LivePix Sponsor -->
  <div id="sponsor" class="bg-gradient-to-br from-brand-600 to-indigo-700 rounded-xl p-6 text-white border border-brand-500/20 shadow-lg relative overflow-hidden">
    <div class="absolute -right-8 -bottom-8 w-24 h-24 bg-white/10 rounded-full blur-xl pointer-events-none"></div>
    <h3 class="font-display font-extrabold text-base tracking-tight mb-2">Apoie o Doug Design</h3>
    <p class="text-xs text-brand-100 leading-relaxed mb-4">
      Este conteúdo é gerado de forma livre e autoral. Se ele te ajudou, você pode contribuir diretamente pelo LivePix!
    </p>
    <div class="flex items-center gap-4 bg-white/10 p-3 rounded-lg border border-white/15">
      <!-- Pix QR Code Graphic -->
      <div class="w-16 h-16 bg-white rounded flex items-center justify-center shrink-0 shadow-inner">
        <div class="grid grid-cols-4 gap-1 p-1 w-full h-full bg-slate-900 rounded">
          <div class="bg-white rounded-sm"></div><div class="bg-white rounded-sm"></div><div class="bg-slate-900"></div><div class="bg-white rounded-sm"></div>
          <div class="bg-slate-900"></div><div class="bg-white rounded-sm"></div><div class="bg-white rounded-sm"></div><div class="bg-slate-900"></div>
          <div class="bg-white rounded-sm"></div><div class="bg-slate-900"></div><div class="bg-white rounded-sm"></div><div class="bg-white rounded-sm"></div>
          <div class="bg-white rounded-sm"></div><div class="bg-white rounded-sm"></div><div class="bg-slate-900"></div><div class="bg-white rounded-sm"></div>
        </div>
      </div>
      <div>
        <p class="text-[10px] uppercase font-bold tracking-widest text-brand-200">Escaneie o Pix</p>
        <p class="text-xs font-semibold mt-1">Chave: livepix.gg/dougdesign</p>
      </div>
    </div>
    <a href="https://livepix.gg/dougdesign" target="_blank" rel="noopener noreferrer" class="block w-full text-center mt-4 bg-white hover:bg-slate-100 text-brand-700 font-bold text-xs uppercase tracking-wider py-2.5 rounded-lg shadow transition-colors font-display">
      Contribuir Online
    </a>
  </div>

  <!-- Widget Amazon Affiliates -->
  <div class="bg-white dark:bg-darkbg-900 rounded-xl p-6 border border-slate-200/50 dark:border-slate-800/50 shadow-sm">
    <div class="flex items-center gap-2 border-b border-slate-100 dark:border-zinc-800 pb-3 mb-4">
      <Icon name="shopping-bag" class="text-brand-600 w-4 h-4" />
      <h3 class="font-display font-extrabold text-sm text-slate-900 dark:text-white">Hardware Recomendado</h3>
    </div>

    <div class="space-y-4">
      <!-- Logitech G502 -->
      <div class="flex gap-3 items-center pb-3 border-b border-slate-100 dark:border-zinc-800/50 last:border-b-0 last:pb-0">
        <div class="w-14 h-14 bg-slate-100 dark:bg-darkbg-950/40 rounded border border-slate-200/50 dark:border-slate-850 flex items-center justify-center shrink-0 overflow-hidden">
          <img src="https://images.unsplash.com/photo-1615663245857-ac93bb7c39e7?q=80&w=150&auto=format&fit=crop" alt="Mouse G502" class="w-full h-full object-cover" />
        </div>
        <div class="flex-grow min-w-0">
          <h4 class="font-semibold text-xs text-slate-900 dark:text-white truncate">Mouse Logitech G502 Hero</h4>
          <p class="text-brand-600 dark:text-brand-500 font-bold text-xs mt-0.5">R$ 279,90</p>
          <a href="https://amazon.com.br" target="_blank" rel="noopener noreferrer" class="text-[10px] text-slate-400 dark:text-zinc-500 hover:text-brand-600 dark:hover:text-brand-500 font-bold flex items-center gap-0.5 mt-1 uppercase">
            Ver na Amazon <Icon name="external-link" class="w-3 h-3" />
          </a>
        </div>
      </div>

      <!-- Keychron K2 -->
      <div class="flex gap-3 items-center pb-3 border-b border-slate-100 dark:border-zinc-800/50 last:border-b-0 last:pb-0">
        <div class="w-14 h-14 bg-slate-100 dark:bg-darkbg-950/40 rounded border border-slate-200/50 dark:border-slate-850 flex items-center justify-center shrink-0 overflow-hidden">
          <img src="https://images.unsplash.com/photo-1587829741301-dc798b83add3?q=80&w=150&auto=format&fit=crop" alt="Teclado Mechanical" class="w-full h-full object-cover" />
        </div>
        <div class="flex-grow min-w-0">
          <h4 class="font-semibold text-xs text-slate-900 dark:text-white truncate">Teclado Mecânico Keychron K2 v2</h4>
          <p class="text-brand-600 dark:text-brand-500 font-bold text-xs mt-0.5">R$ 689,00</p>
          <a href="https://amazon.com.br" target="_blank" rel="noopener noreferrer" class="text-[10px] text-slate-400 dark:text-zinc-500 hover:text-brand-600 dark:hover:text-brand-500 font-bold flex items-center gap-0.5 mt-1 uppercase">
            Ver na Amazon <Icon name="external-link" class="w-3 h-3" />
          </a>
        </div>
      </div>

      <!-- HyperX QuadCast -->
      <div class="flex gap-3 items-center">
        <div class="w-14 h-14 bg-slate-100 dark:bg-darkbg-950/40 rounded border border-slate-200/50 dark:border-slate-850 flex items-center justify-center shrink-0 overflow-hidden">
          <img src="https://images.unsplash.com/photo-1590608897129-79da98d15969?q=80&w=150&auto=format&fit=crop" alt="Microfone QuadCast" class="w-full h-full object-cover" />
        </div>
        <div class="flex-grow min-w-0">
          <h4 class="font-semibold text-xs text-slate-900 dark:text-white truncate">Microfone HyperX QuadCast S</h4>
          <p class="text-brand-600 dark:text-brand-500 font-bold text-xs mt-0.5">R$ 899,00</p>
          <a href="https://amazon.com.br" target="_blank" rel="noopener noreferrer" class="text-[10px] text-slate-400 dark:text-zinc-500 hover:text-brand-600 dark:hover:text-brand-500 font-bold flex items-center gap-0.5 mt-1 uppercase">
            Ver na Amazon <Icon name="external-link" class="w-3 h-3" />
          </a>
        </div>
      </div>
    </div>
  </div>
</div>
