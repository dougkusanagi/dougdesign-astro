---
import Icon from './Icon.astro';
import AdSense from './AdSense.astro';
import LivePixWidget from './LivePixWidget.astro';

const maisLidos = [
  { category: 'Games', title: 'Palia: Royal Highlands. Como se preparar para a nova expansão', link: '/palia-royal-highlands-como-se-preparar-expansao' },
  { category: 'IA', title: 'O que é o modelo DeepSeek e por que ele está mudando o mercado de IA?', link: '/deepseek-revolucao-ia-chinesa-algoritmos-eficientes' },
  { category: 'Games', title: 'Melhores jogos curtos do Xbox Game Pass em 2026 para zerar', link: '/melhores-jogos-curtos-game-pass-2026' },
  { category: 'Web Design', title: 'Web Components em 2026: a chave para componentes reutilizáveis', link: '/web-components-em-2026-a-chave-para-componentes-reutilizaveis-e-um-design-system-robusto-no-seu-projeto-web' },
  { category: 'Programação', title: 'TypeScript 2026: recursos modernos e boas práticas em projetos', link: '/typescript-2026-recursos-modernos-boas-praticas-projetos-escalaveis' },
  { category: 'Games', title: 'Calendário de lançamentos de games 2026 no Brasil', link: '/calendario-lancamentos-games-2026-ps5-xbox-switch-2-pc' },
  { category: 'Games', title: 'PS Plus de Abril: quais jogos baixar primeiro em seu console', link: '/ps-plus-abril-2026-quais-jogos-baixar-primeiro' },
  { category: 'Tecnologia', title: 'Vale comprar o Switch 2 se você já tem a versão OLED?', link: '/switch-2-vale-para-quem-ja-tem-switch-oled' },
  { category: 'Games', title: 'Xbox Game Pass em Abril: ordem recomendada para jogar os títulos', link: '/game-pass-abril-2026-ordem-recomendada-para-jogar' },
  { category: 'Web Design', title: 'Como planejar wireframes focados em conversão de cliques', link: '/do-desenho-ao-codigo-novas-ias-que-transformam-wireframes-feitos-a-mao-em-sites-prontos' },
];
---

<div class="space-y-8 lg:col-span-1">
  <LivePixWidget />

  <!-- Mais Lidos -->
  <div class="reveal rounded-2xl border border-ink-900/[0.07] bg-white p-6 shadow-card dark:border-white/[0.07] dark:bg-ink-900 dark:shadow-card-dark">
    <div class="mb-4 flex items-center gap-2.5 border-b border-ink-900/[0.06] pb-4 dark:border-white/[0.06]">
      <span class="flex h-8 w-8 items-center justify-center rounded-lg bg-gradient-to-br from-brand-500 to-brand-700 text-white shadow-glow-sm">
        <Icon name="flame" class="h-4 w-4" />
      </span>
      <h2 class="font-display text-base font-extrabold tracking-tight text-ink-950 dark:text-white">Mais Lidos</h2>
    </div>

    <ol class="divide-y divide-ink-900/[0.05] dark:divide-white/[0.05]">
      {maisLidos.slice(0, 7).map((item, index) => (
        <li>
          <article class="group relative flex items-start gap-4 py-3.5">
            <a href={item.link} class="absolute inset-0 z-20" aria-label={item.title}></a>
            <span class:list={[
              'w-8 shrink-0 font-display text-2xl font-extrabold tracking-tight transition-colors duration-300',
              index < 3 ? 'text-brand-600 dark:text-brand-400' : 'text-ink-200 dark:text-ink-700',
            ]}>
              {String(index + 1).padStart(2, '0')}
            </span>
            <div>
              <span class="font-display text-[9px] font-extrabold uppercase tracking-[0.18em] text-brand-600 dark:text-brand-400">{item.category}</span>
              <h3 class="mt-0.5 font-display text-xs font-bold leading-snug text-ink-800 transition-colors duration-300 group-hover:text-brand-600 dark:text-ink-200 dark:group-hover:text-brand-300">
                {item.title}
              </h3>
            </div>
          </article>
        </li>
      ))}
    </ol>
  </div>

  <AdSense
    slot="3980100424"
    format="auto"
    fullWidthResponsive={true}
    style="display:block"
    simulatedText="Google AdSense - Retângulo Médio Lateral"
    class="w-full"
  />

  <!-- Hardware Recomendado -->
  <div class="reveal rounded-2xl border border-ink-900/[0.07] bg-white p-6 shadow-card dark:border-white/[0.07] dark:bg-ink-900 dark:shadow-card-dark">
    <div class="mb-4 flex items-center gap-2.5 border-b border-ink-900/[0.06] pb-4 dark:border-white/[0.06]">
      <span class="flex h-8 w-8 items-center justify-center rounded-lg bg-ink-900 text-white dark:bg-white dark:text-ink-900">
        <Icon name="shopping-bag" class="h-4 w-4" />
      </span>
      <h2 class="font-display text-base font-extrabold tracking-tight text-ink-950 dark:text-white">Hardware Recomendado</h2>
    </div>

    <div class="space-y-4">
      <div class="group flex items-center gap-3 border-b border-ink-900/[0.05] pb-4 last:border-b-0 last:pb-0 dark:border-white/[0.05]">
        <div class="h-14 w-14 shrink-0 overflow-hidden rounded-xl border border-ink-900/[0.06] bg-ink-100 dark:border-white/[0.06] dark:bg-ink-950">
          <img src="https://images.unsplash.com/photo-1615663245857-ac93bb7c39e7?q=80&w=150&auto=format&fit=crop" alt="Mouse G502" class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-110" loading="lazy" />
        </div>
        <div class="min-w-0 flex-grow">
          <h3 class="truncate text-xs font-semibold text-ink-900 dark:text-white">Mouse Logitech G502 Hero</h3>
          <p class="mt-0.5 text-xs font-bold text-brand-600 dark:text-brand-400">R$ 279,90</p>
          <a href="https://amazon.com.br" target="_blank" rel="noopener noreferrer" class="mt-1 flex items-center gap-0.5 text-[10px] font-bold uppercase text-ink-400 transition-colors hover:text-brand-600 dark:hover:text-brand-400">
            Ver na Amazon <Icon name="external-link" class="h-3 w-3" />
          </a>
        </div>
      </div>

      <div class="group flex items-center gap-3 border-b border-ink-900/[0.05] pb-4 last:border-b-0 last:pb-0 dark:border-white/[0.05]">
        <div class="h-14 w-14 shrink-0 overflow-hidden rounded-xl border border-ink-900/[0.06] bg-ink-100 dark:border-white/[0.06] dark:bg-ink-950">
          <img src="https://images.unsplash.com/photo-1587829741301-dc798b83add3?q=80&w=150&auto=format&fit=crop" alt="Teclado Mechanical" class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-110" loading="lazy" />
        </div>
        <div class="min-w-0 flex-grow">
          <h3 class="truncate text-xs font-semibold text-ink-900 dark:text-white">Teclado Mecânico Keychron K2 v2</h3>
          <p class="mt-0.5 text-xs font-bold text-brand-600 dark:text-brand-400">R$ 689,00</p>
          <a href="https://amazon.com.br" target="_blank" rel="noopener noreferrer" class="mt-1 flex items-center gap-0.5 text-[10px] font-bold uppercase text-ink-400 transition-colors hover:text-brand-600 dark:hover:text-brand-400">
            Ver na Amazon <Icon name="external-link" class="h-3 w-3" />
          </a>
        </div>
      </div>

      <div class="group flex items-center gap-3">
        <div class="h-14 w-14 shrink-0 overflow-hidden rounded-xl border border-ink-900/[0.06] bg-ink-100 dark:border-white/[0.06] dark:bg-ink-950">
          <img src="https://images.unsplash.com/photo-1590608897129-79da98d15969?q=80&w=150&auto=format&fit=crop" alt="Microfone QuadCast" class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-110" loading="lazy" />
        </div>
        <div class="min-w-0 flex-grow">
          <h3 class="truncate text-xs font-semibold text-ink-900 dark:text-white">Microfone HyperX QuadCast S</h3>
          <p class="mt-0.5 text-xs font-bold text-brand-600 dark:text-brand-400">R$ 899,00</p>
          <a href="https://amazon.com.br" target="_blank" rel="noopener noreferrer" class="mt-1 flex items-center gap-0.5 text-[10px] font-bold uppercase text-ink-400 transition-colors hover:text-brand-600 dark:hover:text-brand-400">
            Ver na Amazon <Icon name="external-link" class="h-3 w-3" />
          </a>
        </div>
      </div>
    </div>
  </div>
</div>
