---
import Icon from './Icon.astro';
import AdSense from './AdSense.astro';
import LivePixWidget from './LivePixWidget.astro';

const maisLidos = [
  { category: 'Games', title: 'Palia: Royal Highlands. Como se preparar para a nova expansão', link: '/palia-royal-highlands-como-se-preparar-expansao' },
  { category: 'IA', title: 'O que é o modelo DeepSeek e por que ele está mudando o mercado de IA?', link: '/deepseek-revolucao-ia-chinesa-algoritmos-eficientes' },
  { category: 'Games', title: 'Melhores jogos curtos do Xbox Game Pass em 2026 para zerar', link: '/melhores-jogos-curtos-game-pass-2026' },
  { category: 'Web Design', title: 'Web Components em 2026: a chave para componentes reutilizáveis', link: '/web-components-em-2026-a-chave-para-componentes-reutilizaveis-e-um-design-system-robusto-no-seu-projeto-web' },
  { category: 'Programação', title: 'TypeScript 2026: recursos modernos e boas práticas em projetos', link: '/typescript-2026-recursos-modernos-boas-praticas-projetos-escalaveis' },
  { category: 'Games', title: 'Calendário de lançamentos de games 2026 no Brasil', link: '/calendario-lancamentos-games-2026-ps5-xbox-switch-2-pc' },
  { category: 'Games', title: 'PS Plus de Abril: quais jogos baixar primeiro em seu console', link: '/ps-plus-abril-2026-quais-jogos-baixar-primeiro' },
  { category: 'Tecnologia', title: 'Vale comprar o Switch 2 se você já tem a versão OLED?', link: '/switch-2-vale-para-quem-ja-tem-switch-oled' },
  { category: 'Games', title: 'Xbox Game Pass em Abril: ordem recomendada para jogar os títulos', link: '/game-pass-abril-2026-ordem-recomendada-para-jogar' },
  { category: 'Web Design', title: 'Como planejar wireframes focados em conversão de cliques', link: '/do-desenho-ao-codigo-novas-ias-que-transformam-wireframes-feitos-a-mao-em-sites-prontos' },
];
---

<div class="lg:col-span-1 space-y-10 font-sans">
  <!-- Widget LivePix Sponsor -->
  <LivePixWidget />

  <!-- Widget Mais Lidos -->
  <div class="bg-white dark:bg-darkbg-900 rounded-xl p-6 border border-slate-200/50 dark:border-slate-800/50 shadow-sm">
    <div class="flex items-center justify-between border-b border-slate-100 dark:border-zinc-800 pb-4 mb-4">
      <h2 class="font-display font-extrabold text-lg text-slate-900 dark:text-white flex items-center gap-2">
        <Icon name="flame" class="text-orange-500 w-4 h-4" /> Mais Lidos
      </h2>
    </div>

    <div class="divide-y divide-slate-100 dark:divide-zinc-800/80">
      {maisLidos.map((item, index) => (
        <article class="group py-3 flex gap-4 items-start relative">
          <a href={item.link} class="absolute inset-0 z-20" aria-label={item.title}></a>
          <div class="font-display font-black text-2xl text-slate-500 dark:text-zinc-400 tracking-tight shrink-0 transition-colors group-hover:text-brand-600/40 w-8">
            {String(index + 1).padStart(2, '0')}
          </div>
          <div>
            <span class="text-[9px] font-extrabold tracking-widest text-brand-600 uppercase font-display">{item.category}</span>
            <h3 class="font-display font-bold text-xs text-slate-800 dark:text-zinc-200 group-hover:text-brand-600 dark:group-hover:text-brand-500 transition-colors mt-0.5 leading-snug">
              {item.title}
            </h3>
          </div>
        </article>
      ))}
    </div>
  </div>

  <!-- AdSense Sidebar Rectangle -->
  <AdSense 
    slot="3980100424" 
    simulatedText="Google AdSense - Retângulo Médio Lateral" 
    style="display:block"
    class="w-full"
  />

  <!-- Widget Amazon Affiliates -->
  <div class="bg-white dark:bg-darkbg-900 rounded-xl p-6 border border-slate-200/50 dark:border-slate-800/50 shadow-sm">
    <div class="flex items-center gap-2 border-b border-slate-100 dark:border-zinc-800 pb-3 mb-4">
      <Icon name="shopping-bag" class="text-brand-600 w-4 h-4" />
      <h2 class="font-display font-extrabold text-sm text-slate-900 dark:text-white">Hardware Recomendado</h2>
    </div>

    <div class="space-y-4">
      <!-- Logitech G502 -->
      <div class="flex gap-3 items-center pb-3 border-b border-slate-100 dark:border-zinc-800/50 last:border-b-0 last:pb-0">
        <div class="w-14 h-14 bg-slate-100 dark:bg-darkbg-950/40 rounded border border-slate-200/50 dark:border-slate-850 flex items-center justify-center shrink-0 overflow-hidden">
          <img src="https://images.unsplash.com/photo-1615663245857-ac93bb7c39e7?q=80&w=150&auto=format&fit=crop" alt="Mouse G502" class="w-full h-full object-cover" />
        </div>
        <div class="flex-grow min-w-0">
          <h3 class="font-semibold text-xs text-slate-900 dark:text-white truncate">Mouse Logitech G502 Hero</h3>
          <p class="text-brand-600 dark:text-brand-500 font-bold text-xs mt-0.5">R$ 279,90</p>
          <a href="https://amazon.com.br" target="_blank" rel="noopener noreferrer" class="text-[10px] text-slate-600 dark:text-zinc-400 hover:text-brand-600 dark:hover:text-brand-500 font-bold flex items-center gap-0.5 mt-1 uppercase">
            Ver na Amazon <Icon name="external-link" class="w-3 h-3" />
          </a>
        </div>
      </div>

      <!-- Keychron K2 -->
      <div class="flex gap-3 items-center pb-3 border-b border-slate-100 dark:border-zinc-800/50 last:border-b-0 last:pb-0">
        <div class="w-14 h-14 bg-slate-100 dark:bg-darkbg-950/40 rounded border border-slate-200/50 dark:border-slate-850 flex items-center justify-center shrink-0 overflow-hidden">
          <img src="https://images.unsplash.com/photo-1587829741301-dc798b83add3?q=80&w=150&auto=format&fit=crop" alt="Teclado Mechanical" class="w-full h-full object-cover" />
        </div>
        <div class="flex-grow min-w-0">
          <h3 class="font-semibold text-xs text-slate-900 dark:text-white truncate">Teclado Mecânico Keychron K2 v2</h3>
          <p class="text-brand-600 dark:text-brand-500 font-bold text-xs mt-0.5">R$ 689,00</p>
          <a href="https://amazon.com.br" target="_blank" rel="noopener noreferrer" class="text-[10px] text-slate-600 dark:text-zinc-400 hover:text-brand-600 dark:hover:text-brand-500 font-bold flex items-center gap-0.5 mt-1 uppercase">
            Ver na Amazon <Icon name="external-link" class="w-3 h-3" />
          </a>
        </div>
      </div>

      <!-- HyperX QuadCast -->
      <div class="flex gap-3 items-center">
        <div class="w-14 h-14 bg-slate-100 dark:bg-darkbg-950/40 rounded border border-slate-200/50 dark:border-slate-850 flex items-center justify-center shrink-0 overflow-hidden">
          <img src="https://images.unsplash.com/photo-1590608897129-79da98d15969?q=80&w=150&auto=format&fit=crop" alt="Microfone QuadCast" class="w-full h-full object-cover" />
        </div>
        <div class="flex-grow min-w-0">
          <h3 class="font-semibold text-xs text-slate-900 dark:text-white truncate">Microfone HyperX QuadCast S</h3>
          <p class="text-brand-600 dark:text-brand-500 font-bold text-xs mt-0.5">R$ 899,00</p>
          <a href="https://amazon.com.br" target="_blank" rel="noopener noreferrer" class="text-[10px] text-slate-600 dark:text-zinc-400 hover:text-brand-600 dark:hover:text-brand-500 font-bold flex items-center gap-0.5 mt-1 uppercase">
            Ver na Amazon <Icon name="external-link" class="w-3 h-3" />
          </a>
        </div>
      </div>
    </div>
  </div>
</div>
