---
---

<article class="reveal relative my-10 overflow-hidden rounded-3xl bg-ink-950 p-7 text-white md:p-9 shadow-glow">
  <!-- Brilhos decorativos -->
  <div class="pointer-events-none absolute -left-20 -top-20 h-56 w-56 rounded-full bg-brand-600/30 blur-[80px]" aria-hidden="true"></div>
  <div class="pointer-events-none absolute -bottom-24 -right-16 h-56 w-56 rounded-full bg-brand-500/20 blur-[80px]" aria-hidden="true"></div>
  <div class="pointer-events-none absolute right-10 top-8 h-28 w-28 rounded-full border-[10px] border-white/[0.06]" aria-hidden="true"></div>

  <div class="relative z-10 flex flex-col justify-between gap-6 md:flex-row md:items-center">
    <div class="max-w-md">
      <p class="font-display text-[10px] font-extrabold uppercase tracking-[0.24em] text-brand-400">Newsletter técnica</p>
      <h4 class="mt-2 font-display text-xl font-extrabold tracking-tight text-balance">O melhor da semana, direto na sua caixa de entrada</h4>
      <p class="mt-2 text-xs leading-relaxed text-white/60">Design, código, IA e games — curadoria semanal, sem spam, para profissionais brasileiros.</p>
    </div>

    <form
      id="newsletter-form"
      toolname="assinarNewsletterTecnica"
      tooldescription="Assina a newsletter técnica de design e desenvolvimento do Doug Design com o endereço de e-mail."
      toolautosubmit="true"
      class="newsletter-form flex w-full max-w-sm shrink-0 items-center gap-2 md:w-auto"
      onsubmit="event.preventDefault(); window.__doug?.trackEvent?.('newsletter_signup_attempt', { placement: 'inline' }); document.getElementById('newsletter-form').classList.add('hidden'); document.getElementById('newsletter-success').classList.remove('hidden');"
    >
      <input
        type="email"
        name="email"
        placeholder="seu@email.com"
        required
        class="w-full min-w-0 flex-grow rounded-full border border-white/15 bg-white/[0.07] px-4 py-2.5 text-xs text-white placeholder-white/40 backdrop-blur-sm transition-all focus:border-brand-400 focus:outline-none focus:ring-2 focus:ring-brand-500/40 md:w-52"
      />
      <button type="submit" class="btn-primary shrink-0 !py-2.5 cursor-pointer border-none">Assinar</button>
    </form>

    <div id="newsletter-success" class="hidden items-center gap-2 py-2 text-xs font-semibold text-emerald-400">
      <span class="flex h-5 w-5 items-center justify-center rounded-full bg-emerald-500/15 text-[10px] font-bold">✓</span>
      Inscrito com sucesso! Obrigado.
    </div>
  </div>
</article>

<style>
  /* :has() — o cartão reage quando o campo está em foco */
  article:has(input:focus) {
    box-shadow: 0 0 0 2px var(--color-brand-500), var(--shadow-glow);
  }
  article:has(input:focus) .btn-primary {
    filter: brightness(1.12);
  }
</style>
