---
import { getPublishedPosts, getPostUrl } from '../lib/blog';

const latestPosts = (await getPublishedPosts()).slice(0, 5);

const formatShortDate = (date: Date) =>
  new Date(date).toLocaleDateString('pt-BR', { day: 'numeric', month: 'short' });
---

<div class="relative z-40 overflow-hidden bg-gradient-to-r from-brand-700 via-brand-600 to-brand-700 text-white select-none">
  <div class="max-w-7xl mx-auto flex items-center gap-3 px-4 sm:px-6 lg:px-8 py-1.5">
    <span class="flex shrink-0 items-center gap-1.5 rounded-full bg-white/15 px-2.5 py-0.5 text-[10px] font-extrabold uppercase tracking-[0.14em] backdrop-blur-sm">
      <span class="h-1.5 w-1.5 rounded-full bg-white animate-pulse-dot"></span>
      Fresco
    </span>

    <div class="marquee-mask relative w-full overflow-hidden">
      <div class="marquee gap-10 text-xs font-semibold" style="--tw-animate-duration: 40s">
        {[...latestPosts, ...latestPosts].map((post) => (
          <a href={getPostUrl(post)} class="group flex shrink-0 items-center gap-2 whitespace-nowrap">
            <span class="text-white/50">◆</span>
            <span class="group-hover:underline underline-offset-4 decoration-white/60">{post.data.title}</span>
            <span class="text-[10px] font-normal text-white/60">{formatShortDate(post.data.pubDate)}</span>
          </a>
        ))}
      </div>
    </div>
  </div>
</div>

<style>
  .marquee:hover { animation-play-state: paused; }
</style>
