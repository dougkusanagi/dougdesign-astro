---
import Icon from './Icon.astro';

interface Props {
  title: string;
  company: string;
  description: string;
  type: 'Remoto' | 'Freelance' | 'Fixo' | 'Híbrido';
  salary: string;
  pubDate: Date;
  link?: string;
}

const { title, company, description, type, salary, pubDate, link = `mailto:contato@dougdesign.com.br?subject=Candidatura: ${encodeURIComponent(title)}` } = Astro.props;

function getRelativeTimeString(date: Date): string {
  const diffMs = Date.now() - date.getTime();
  const diffHours = Math.floor(diffMs / 3600000);
  const diffDays = Math.floor(diffMs / 86400000);

  if (diffHours <= 0) return 'Agora mesmo';
  if (diffHours < 24) return `Há ${diffHours}h`;
  if (diffDays === 1) return 'Ontem';
  return `Há ${diffDays} dias`;
}

const relativeTime = getRelativeTimeString(pubDate);

const typeStyles: Record<string, string> = {
  Remoto: 'bg-brand-100 text-brand-700 dark:bg-brand-900/50 dark:text-brand-300',
  Freelance: 'bg-emerald-100 text-emerald-700 dark:bg-emerald-900/40 dark:text-emerald-300',
  Fixo: 'bg-violet-100 text-violet-700 dark:bg-violet-900/40 dark:text-violet-300',
  Híbrido: 'bg-amber-100 text-amber-700 dark:bg-amber-900/40 dark:text-amber-300',
};
---

<div class="group flex flex-col justify-between rounded-xl border border-ink-900/[0.07] bg-white p-5 transition-all duration-500 ease-[cubic-bezier(0.16,1,0.3,1)] hover:-translate-y-1 hover:border-brand-500/40 hover:shadow-glow-sm dark:border-white/[0.07] dark:bg-ink-900 spotlight">
  <div>
    <div class="mb-3 flex items-center gap-2">
      <span class={`rounded-full px-2.5 py-1 font-display text-[9px] font-extrabold uppercase tracking-[0.14em] ${typeStyles[type]}`}>{type}</span>
      <span class="text-[10px] font-semibold text-ink-400 dark:text-ink-500">{relativeTime}</span>
    </div>
    <h3 class="font-display text-sm font-bold leading-snug text-ink-900 transition-colors group-hover:text-brand-600 dark:text-white dark:group-hover:text-brand-300">{title}</h3>
    <p class="mt-1 text-[11px] font-semibold uppercase tracking-wider text-ink-400 dark:text-ink-500">{company}</p>
    <p class="mt-2 text-xs leading-relaxed text-ink-500 line-clamp-2 dark:text-ink-400">{description}</p>
  </div>
  <div class="mt-5 flex items-center justify-between border-t border-ink-900/[0.06] pt-3 text-xs font-semibold dark:border-white/[0.06]">
    <span class="text-ink-900 dark:text-ink-200">{salary}</span>
    <a href={link} class="relative z-10 flex items-center gap-0.5 font-display text-[11px] font-bold uppercase tracking-wider text-brand-600 transition-transform duration-300 hover:translate-x-0.5 dark:text-brand-400">
      Candidatar <Icon name="arrow-right" class="h-3.5 w-3.5" />
    </a>
  </div>
</div>
