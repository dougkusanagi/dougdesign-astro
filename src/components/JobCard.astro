---
import Icon from './Icon.astro';

interface Props {
  title: string;
  company: string;
  description: string;
  type: 'Remoto' | 'Freelance' | 'Fixo' | 'Híbrido';
  salary: string;
  pubDate: Date;
  link?: string;
}

const { title, company, description, type, salary, pubDate, link = `mailto:contato@dougdesign.com.br?subject=Candidatura: ${encodeURIComponent(title)}` } = Astro.props;

// Helper to format mock relative time
function getRelativeTimeString(date: Date): string {
  // Use simulated base date matching the metadata date (2026-06-22)
  const base = new Date('2026-06-22T22:00:00');
  const diffMs = base.getTime() - date.getTime();
  const diffHours = Math.floor(diffMs / 3600000);
  const diffDays = Math.floor(diffMs / 86400000);

  if (diffHours <= 0) return 'Há 2h';
  if (diffHours < 24) return `Há ${diffHours}h`;
  if (diffDays === 1) return 'Ontem';
  return `Há ${diffDays} dias`;
}

const relativeTime = getRelativeTimeString(pubDate);

// Dynamic colors for type tags
const typeColors = {
  Remoto: 'bg-blue-100 dark:bg-blue-900/40 text-blue-700 dark:text-blue-300',
  Freelance: 'bg-emerald-100 dark:bg-emerald-900/40 text-emerald-700 dark:text-emerald-300',
  Fixo: 'bg-purple-100 dark:bg-purple-900/40 text-purple-700 dark:text-purple-300',
  Híbrido: 'bg-amber-100 dark:bg-amber-900/40 text-amber-700 dark:text-amber-300',
};
---

<div class="bg-slate-50 dark:bg-darkbg-950/40 p-5 rounded-xl border border-slate-200/50 dark:border-slate-800/50 flex flex-col justify-between hover:border-brand-500/50 transition-colors">
  <div>
    <div class="flex items-center gap-2 mb-3">
      <span class={`text-[9px] font-extrabold uppercase px-2 py-0.5 rounded ${typeColors[type]}`}>{type}</span>
      <span class="text-slate-400 dark:text-zinc-500 text-[10px]">{relativeTime}</span>
    </div>
    <h4 class="font-display font-bold text-sm text-slate-900 dark:text-white leading-snug">{title}</h4>
    <p class="text-xs text-slate-500 dark:text-zinc-400 mt-2 line-clamp-2">{description}</p>
  </div>
  <div class="flex items-center justify-between mt-5 pt-3 border-t border-slate-200/30 dark:border-zinc-800/30 text-xs font-semibold">
    <span class="text-slate-900 dark:text-zinc-300">{salary}</span>
    <a href={link} class="text-brand-600 hover:underline flex items-center gap-0.5">
      Candidatar <Icon name="chevron-right" class="w-3.5 h-3.5" />
    </a>
  </div>
</div>
