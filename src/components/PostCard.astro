---
import { Image } from 'astro:assets';
import Icon from './Icon.astro';

interface Props {
  post: {
    id: string;
    data: {
      title: string;
      meta_description?: string;
      description?: string;
      pubDate: Date;
      author: string;
      category: string;
      image?: any;
      readingTime?: string;
    }
  };
  variant: 'hero' | 'sidebar' | 'highlight' | 'feed';
  class?: string;
  loading?: 'lazy' | 'eager';
  fetchpriority?: 'high' | 'low' | 'auto';
}

const { post, variant, class: className = '', loading = 'lazy', fetchpriority = 'auto' } = Astro.props;
const { title, description, pubDate, author, category, image, readingTime } = post.data;

// Format date to: 22 Abr, 2026 or similar
function formatDate(date: Date): string {
  const months = ['Jan', 'Fev', 'Mar', 'Abr', 'Mai', 'Jun', 'Jul', 'Ago', 'Set', 'Out', 'Nov', 'Dez'];
  const day = date.getDate();
  const month = months[date.getMonth()];
  const year = date.getFullYear();
  
  // Calculate relative time if it's very recent (in June 2026 context)
  const base = new Date('2026-06-22T22:00:00');
  const diffMs = base.getTime() - date.getTime();
  const diffDays = Math.floor(diffMs / 86400000);

  if (diffDays === 0) return 'Hoje';
  if (diffDays === 1) return 'Ontem';
  if (diffDays > 1 && diffDays <= 3) return `Há ${diffDays} dias`;
  
  return `${day} ${month}, ${year}`;
}

const formattedDate = formatDate(pubDate);
---

{variant === 'hero' && (
  <div class={`group flex flex-col justify-start relative ${className}`}>
    <a href={`/${post.id}`} class="absolute inset-0 z-20" aria-label={title}></a>
    
    <div class="relative w-full h-[380px] sm:h-[450px]">
      <div class="absolute inset-0 aftermath-img-clip overflow-hidden bg-slate-200 dark:bg-darkbg-900 rounded-xl shadow-lg">
        {image && (
          <Image 
            src={image} 
            alt={title}
            width={1200}
            height={675}
            loading={loading}
            fetchpriority={fetchpriority}
            class="w-full h-full object-cover object-center group-hover:scale-102 transition-transform duration-700 ease-out"
          />
        )}
      </div>
      
      <!-- Metadados no Notch -->
      <div class="absolute bottom-0 left-0 pt-2.5 pr-8 flex items-center gap-3 text-xs font-bold transition-colors duration-300 z-30">
        <span class="text-brand-600 dark:text-brand-500 uppercase tracking-widest font-display text-[11px]">{category}</span>
        <span class="text-slate-600 dark:text-zinc-400 font-normal">/</span>
        <span class="text-slate-700 dark:text-zinc-300 font-semibold truncate max-w-[130px] sm:max-w-none">{author}</span>
        <span class="text-slate-600 dark:text-zinc-400 font-normal">-</span>
        <span class="text-slate-650 dark:text-zinc-350 font-semibold">{formattedDate}</span>
      </div>
    </div>

    <!-- Título e Excerpt abaixo da imagem -->
    <div class="mt-4 max-w-3xl">
      <h1 class="font-display font-extrabold text-2xl sm:text-3xl tracking-tight leading-tight text-slate-900 dark:text-white group-hover:text-brand-600 dark:group-hover:text-brand-500 transition-colors">
        {title}
      </h1>
      <p class="text-slate-600 dark:text-zinc-400 text-sm font-normal leading-relaxed mt-2.5">
        {description}
      </p>
    </div>
  </div>
)}

{variant === 'sidebar' && (
  <article class={`flex-1 group overflow-hidden rounded-xl bg-white dark:bg-darkbg-900 border border-slate-200/60 dark:border-slate-800/60 flex flex-col hover:-translate-y-1 hover:shadow-xl transition-all duration-300 neon-border-hover relative ${className}`} data-search-title={title.toLowerCase()} data-search-desc={description ? description.toLowerCase() : ''}>
    <a href={`/${post.id}`} class="absolute inset-0 z-20" aria-label={title}></a>
    
    <div class="w-full h-36 overflow-hidden relative shrink-0 bg-slate-100 dark:bg-slate-950">
      {image && (
        <Image 
          src={image} 
          alt={title}
          width={600}
          height={338}
          loading={loading}
          class="w-full h-full object-cover group-hover:scale-103 transition-transform duration-500"
        />
      )}
      <span class="absolute top-3 left-3 bg-zinc-950/80 backdrop-blur-sm text-zinc-300 text-[9px] font-extrabold uppercase tracking-widest px-2 py-0.5 rounded font-display">
        {category}
      </span>
    </div>
    <div class="p-4 flex-grow flex flex-col justify-between">
      <div>
        <div class="flex items-center justify-between text-[11px] text-slate-600 dark:text-zinc-400 mb-1">
          <span>Por {author}</span>
          <span>{formattedDate}</span>
        </div>
        <h3 class="font-display font-bold text-sm leading-snug text-slate-900 dark:text-white group-hover:text-brand-600 dark:group-hover:text-brand-500 transition-colors">
          {title}
        </h3>
      </div>
      <Icon name="arrow-right" class="w-4 h-4 text-slate-400 group-hover:text-brand-600 group-hover:translate-x-1 transition-all mt-3 ml-auto relative z-30" />
    </div>
  </article>
)}

{variant === 'highlight' && (
  <article class={`group relative overflow-hidden rounded-xl bg-white dark:bg-darkbg-900 border border-slate-200/50 dark:border-slate-800/50 shadow-sm flex flex-col hover:-translate-y-1 transition-transform duration-300 ${className}`}>
    <a href={`/${post.id}`} class="absolute inset-0 z-20" aria-label={title}></a>
    <div class="w-full h-48 overflow-hidden relative bg-slate-100 dark:bg-slate-950">
      {image && (
        <Image 
          src={image} 
          alt={title}
          width={600}
          height={338}
          loading={loading}
          class="w-full h-full object-cover group-hover:scale-102 transition-transform duration-500"
        />
      )}
      <span class="absolute top-3 left-3 bg-brand-600 text-white text-[9px] font-extrabold px-2 py-0.5 rounded tracking-wider uppercase font-display">
        {category}
      </span>
    </div>
    <div class="p-5 flex-grow">
      <h3 class="font-display font-extrabold text-base text-slate-900 dark:text-white leading-snug group-hover:text-brand-600 dark:group-hover:text-brand-500 transition-colors">
        {title}
      </h3>
      <p class="text-xs text-slate-650 dark:text-zinc-350 mt-2 line-clamp-2">
        {description}
      </p>
    </div>
  </article>
)}

{variant === 'feed' && (
  <article class={`group flex flex-col md:flex-row gap-6 items-start pb-8 border-b border-slate-200/60 dark:border-zinc-800/60 relative ${className}`}>
    <a href={`/${post.id}`} class="absolute inset-0 z-20" aria-label={title}></a>
    <div class="w-full md:w-64 h-44 rounded-xl overflow-hidden bg-zinc-100 dark:bg-darkbg-950 border border-slate-200/50 dark:border-slate-800/50 shrink-0 relative">
      {image && (
        <Image 
          src={image} 
          alt={title}
          width={600}
          height={338}
          loading={loading}
          class="w-full h-full object-cover group-hover:scale-103 transition-transform duration-500"
        />
      )}
      <span class="absolute top-3 left-3 bg-zinc-950/80 backdrop-blur-sm text-zinc-300 text-[9px] font-extrabold uppercase tracking-widest px-2 py-0.5 rounded font-display">
        {category}
      </span>
    </div>
    <div class="flex flex-col justify-between h-auto md:h-44 py-1">
      <div>
        <h3 class="font-display font-extrabold text-xl text-slate-900 dark:text-white group-hover:text-brand-600 dark:group-hover:text-brand-500 transition-colors leading-snug">
          {title}
        </h3>
        <p class="text-slate-650 dark:text-zinc-350 text-xs mt-2 line-clamp-2 leading-relaxed">
          {description}
        </p>
      </div>
      <div class="flex items-center gap-4 text-[11px] text-slate-650 dark:text-zinc-400 mt-4 font-semibold">
        <span class="text-slate-800 dark:text-zinc-300">{author}</span>
        <span>•</span>
        <span>{formattedDate}</span>
        {readingTime && (
          <>
            <span>•</span>
            <span class="flex items-center gap-1"><Icon name="clock" class="w-3 h-3" /> {readingTime}</span>
          </>
        )}
      </div>
    </div>
  </article>
)}
