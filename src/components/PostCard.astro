---
import { Image } from 'astro:assets';
import Icon from './Icon.astro';
import { getPostUrl, getPostSlug, normalizeCategoryLabel } from '../lib/blog';

interface Props {
  post: {
    id: string;
    data: {
      title: string;
      meta_description?: string;
      description?: string;
      pubDate: Date;
      author: string;
      category: string;
      image?: any;
      readingTime?: string;
    }
  };
  variant: 'hero' | 'sidebar' | 'highlight' | 'feed';
  class?: string;
  loading?: 'lazy' | 'eager';
  fetchpriority?: 'high' | 'low' | 'auto';
}

const { post, variant, class: className = '', loading = 'lazy', fetchpriority = 'auto' } = Astro.props;
const { title, description, pubDate, author, category, image, readingTime } = post.data;
const postUrl = getPostUrl(post as any);
const postSlug = getPostSlug(post as any);
const categoryLabel = normalizeCategoryLabel(category);

function formatDate(date: Date): string {
  const months = ['Jan', 'Fev', 'Mar', 'Abr', 'Mai', 'Jun', 'Jul', 'Ago', 'Set', 'Out', 'Nov', 'Dez'];
  const day = date.getDate();
  const month = months[date.getMonth()];
  const year = date.getFullYear();

  const diffMs = Date.now() - date.getTime();
  const diffDays = Math.floor(diffMs / 86400000);

  if (diffDays <= 0) return 'Hoje';
  if (diffDays === 1) return 'Ontem';
  if (diffDays > 1 && diffDays <= 3) return `Há ${diffDays} dias`;

  return `${day} ${month}, ${year}`;
}

const formattedDate = formatDate(pubDate);
const cardSizes = {
  hero: '(max-width: 1024px) 100vw, 66vw',
  sidebar: '(max-width: 768px) 100vw, 33vw',
  highlight: '(max-width: 640px) 85vw, (max-width: 1024px) 45vw, 31vw',
  feed: '(max-width: 768px) 100vw, 340px',
};
const vtCover = `post-cover-${postSlug}`;
---

{variant === 'hero' && (
  <article class={`cq group relative overflow-hidden rounded-3xl bg-ink-950 text-white shadow-card-dark spotlight arc-border ${className}`}>
    <a href={postUrl} class="absolute inset-0 z-30" aria-label={title}></a>

    <!-- Imagem cinematográfica com morph via View Transition -->
    <div class="absolute inset-0 overflow-hidden">
      {image && (
        <Image
          src={image}
          alt={title}
          width={1280}
          height={720}
          widths={[480, 768, 1024, 1280]}
          sizes={cardSizes.hero}
          layout="constrained"
          loading={loading}
          fetchpriority={fetchpriority}
          style={`view-transition-name: ${vtCover}`}
          class="h-full w-full object-cover object-center transition-transform duration-[1200ms] ease-[cubic-bezier(0.16,1,0.3,1)] group-hover:scale-[1.05]"
        />
      )}
      <div class="absolute inset-0 bg-gradient-to-t from-ink-950 via-ink-950/45 to-ink-950/5"></div>
      <div class="absolute inset-0 bg-gradient-to-r from-ink-950/55 to-transparent"></div>
    </div>

    <!-- Conteúdo sobreposto -->
    <div class="relative z-20 flex h-full min-h-[26rem] sm:min-h-[30rem] flex-col justify-end p-6 sm:p-9">
      <div class="flex items-center gap-3 text-[11px] font-bold uppercase tracking-[0.18em]">
        <span class="rounded-full bg-brand-600 px-3 py-1 font-display shadow-glow-sm">{categoryLabel}</span>
        <span class="text-white/70 font-semibold normal-case tracking-normal">{formattedDate}</span>
      </div>

      <h2 class="mt-4 max-w-2xl font-display text-2xl sm:text-4xl font-extrabold leading-[1.08] tracking-tight text-balance">
        <span class="bg-gradient-to-r from-white to-white bg-[length:0%_2px] bg-left-bottom bg-no-repeat transition-[background-size] duration-700 group-hover:bg-[length:100%_2px] decoration-clone">
          {title}
        </span>
      </h2>

      {description && (
        <p class="mt-3 max-w-xl text-sm leading-relaxed text-white/75 line-clamp-2">{description}</p>
      )}

      <div class="mt-5 flex items-center gap-3 text-xs font-semibold text-white/70">
        <span class="flex h-7 w-7 items-center justify-center rounded-full bg-white/10 font-display text-[10px] font-extrabold uppercase backdrop-blur-sm">
          {author.split(' ').map(w => w[0]).slice(0, 2).join('')}
        </span>
        <span>{author}</span>
        {readingTime && <><span class="text-white/30">/</span><span class="flex items-center gap-1"><Icon name="clock" class="h-3.5 w-3.5" />{readingTime}</span></>}
        <span class="ml-auto hidden sm:inline-flex items-center gap-1.5 font-display uppercase tracking-widest text-[10px] text-white/80 transition-transform duration-500 group-hover:translate-x-1">
          Ler artigo <Icon name="arrow-right" class="h-3.5 w-3.5" />
        </span>
      </div>
    </div>
  </article>
)}

{variant === 'sidebar' && (
  <article class={`cq card group relative flex flex-col overflow-hidden rounded-2xl border border-ink-900/[0.07] bg-white shadow-card transition-all duration-500 ease-[cubic-bezier(0.16,1,0.3,1)] hover:-translate-y-1.5 hover:shadow-glow dark:border-white/[0.07] dark:bg-ink-900 dark:shadow-card-dark spotlight arc-border ${className}`} data-search-title={title.toLowerCase()} data-search-desc={description ? description.toLowerCase() : ''}>
    <a href={postUrl} class="absolute inset-0 z-30" aria-label={title}></a>

    <div class="card-media relative shrink-0 overflow-hidden bg-ink-100 dark:bg-ink-950">
      {image && (
        <Image
          src={image}
          alt={title}
          width={640}
          height={360}
          widths={[320, 480, 640]}
          sizes={cardSizes.sidebar}
          layout="constrained"
          loading={loading}
          class="h-full w-full object-cover transition-transform duration-700 ease-[cubic-bezier(0.16,1,0.3,1)] group-hover:scale-[1.06]"
        />
      )}
      <span class="absolute left-3 top-3 z-10 rounded-full bg-ink-950/70 px-2.5 py-1 font-display text-[9px] font-extrabold uppercase tracking-[0.16em] text-white backdrop-blur-md">
        {categoryLabel}
      </span>
    </div>

    <div class="card-body flex flex-grow flex-col justify-between p-5">
      <div>
        <h3 class="font-display text-[15px] font-bold leading-snug tracking-tight text-ink-900 transition-colors duration-300 text-balance group-hover:text-brand-600 dark:text-white dark:group-hover:text-brand-300">
          {title}
        </h3>
        {description && (
          <p class="card-desc mt-2 hidden text-xs leading-relaxed text-ink-500 line-clamp-2 dark:text-ink-400">{description}</p>
        )}
      </div>
      <div class="mt-4 flex items-center justify-between text-[11px] font-semibold text-ink-400 dark:text-ink-500">
        <span>{formattedDate}</span>
        <span class="flex h-7 w-7 items-center justify-center rounded-full border border-ink-900/10 text-ink-400 transition-all duration-500 group-hover:border-brand-600 group-hover:bg-brand-600 group-hover:text-white dark:border-white/10">
          <Icon name="arrow-right" class="h-3.5 w-3.5 transition-transform duration-500 group-hover:-rotate-45" />
        </span>
      </div>
    </div>
  </article>
)}

{variant === 'highlight' && (
  <article class={`cq group relative flex h-full flex-col overflow-hidden rounded-2xl bg-ink-950 text-white shadow-card-dark spotlight ${className}`}>
    <a href={postUrl} class="absolute inset-0 z-30" aria-label={title}></a>

    <div class="relative h-44 overflow-hidden">
      {image && (
        <Image
          src={image}
          alt={title}
          width={640}
          height={360}
          widths={[320, 480, 640]}
          sizes={cardSizes.highlight}
          layout="constrained"
          loading={loading}
          class="h-full w-full object-cover transition-transform duration-700 ease-[cubic-bezier(0.16,1,0.3,1)] group-hover:scale-[1.06]"
        />
      )}
      <div class="absolute inset-0 bg-gradient-to-t from-ink-950 to-transparent"></div>
      <span class="absolute left-3 top-3 rounded-full bg-brand-600 px-2.5 py-1 font-display text-[9px] font-extrabold uppercase tracking-[0.16em] shadow-glow-sm">
        {categoryLabel}
      </span>
    </div>

    <div class="flex flex-grow flex-col p-5">
      <h3 class="font-display text-base font-bold leading-snug tracking-tight text-balance transition-colors duration-300 group-hover:text-brand-300">
        {title}
      </h3>
      {description && (
        <p class="mt-2 text-xs leading-relaxed text-white/60 line-clamp-2">{description}</p>
      )}
      <div class="mt-auto pt-4 text-[11px] font-semibold text-white/50">
        {author} · {formattedDate}
      </div>
    </div>
  </article>
)}

{variant === 'feed' && (
  <article class={`feed-card group relative flex flex-col gap-0 overflow-hidden rounded-2xl border border-ink-900/[0.07] bg-white shadow-card transition-all duration-500 ease-[cubic-bezier(0.16,1,0.3,1)] hover:-translate-y-1 hover:shadow-glow sm:flex-row sm:items-stretch sm:p-5 dark:border-white/[0.07] dark:bg-ink-900 dark:shadow-card-dark spotlight arc-border ${className}`}>
    <a href={postUrl} class="absolute inset-0 z-30" aria-label={title}></a>

    <div class="feed-media relative shrink-0 overflow-hidden sm:w-[340px] sm:rounded-xl sm:m-0 -m-px rounded-t-2xl sm:rounded-l-2xl sm:rounded-tr-none bg-ink-100 dark:bg-ink-950">
      {image && (
        <Image
          src={image}
          alt={title}
          width={640}
          height={360}
          widths={[320, 480, 640]}
          sizes={cardSizes.feed}
          layout="constrained"
          loading={loading}
          class="h-full w-full object-cover transition-transform duration-700 ease-[cubic-bezier(0.16,1,0.3,1)] group-hover:scale-[1.06]"
        />
      )}
      <span class="absolute left-3 top-3 rounded-full bg-ink-950/70 px-2.5 py-1 font-display text-[9px] font-extrabold uppercase tracking-[0.16em] text-white backdrop-blur-md">
        {categoryLabel}
      </span>
    </div>

    <div class="flex min-w-0 flex-col justify-center py-4 px-4 sm:px-6 sm:py-5">
      <h3 class="font-display text-xl font-extrabold leading-snug tracking-tight text-ink-900 transition-colors duration-300 text-balance group-hover:text-brand-600 dark:text-white dark:group-hover:text-brand-300">
        {title}
      </h3>
      {description && (
        <p class="mt-2 text-[15px] leading-relaxed text-ink-500 line-clamp-2 dark:text-ink-400">{description}</p>
      )}
      <div class="mt-4 flex flex-wrap items-center gap-x-3 gap-y-1 text-[13px] font-semibold text-ink-400 dark:text-ink-500">
        <span class="text-ink-700 dark:text-ink-300">{author}</span>
        <span class="text-ink-300 dark:text-ink-700">/</span>
        <span>{formattedDate}</span>
        {readingTime && (
          <>
            <span class="text-ink-300 dark:text-ink-700">/</span>
            <span class="flex items-center gap-1"><Icon name="clock" class="h-3 w-3" /> {readingTime}</span>
          </>
        )}
      </div>
    </div>
  </article>
)}

<style>
  /* ── Container Queries: o card se adapta ao espaço que recebe ── */
  .cq {
    container-type: inline-size;
  }

  /* Card "sidebar": vira layout horizontal apenas com largura confortável */
  @container (min-width: 640px) {
    .card {
      flex-direction: row;
      align-items: stretch;
    }
    .card .card-media {
      width: 48%;
      flex-shrink: 0;
      aspect-ratio: 4 / 3;
    }
    .card .card-desc {
      display: -webkit-box;
    }
  }
  @container (max-width: 639px) {
    .card {
      flex-direction: column;
    }
    .card .card-media {
      width: 100%;
      aspect-ratio: 16 / 9;
    }
  }

  /* Card "feed": mobile vertical, desktop horizontal com imagens robustas */
  .feed-card .feed-media {
    aspect-ratio: 16 / 9;
  }
  @media (min-width: 640px) {
    .feed-card .feed-media {
      width: 340px;
      aspect-ratio: 4 / 3;
    }
  }
</style>
