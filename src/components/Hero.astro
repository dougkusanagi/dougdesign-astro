---
import { getPublishedPosts, normalizeCategoryLabel, slugifyCategory } from '../lib/blog';
import PostCard from './PostCard.astro';
import Icon from './Icon.astro';

const allPosts = await getPublishedPosts();
const [mainPost, sidePost1] = allPosts;
const categories = [...new Set(allPosts.map((p) => normalizeCategoryLabel(p.data.category)))].slice(0, 8);
---

<section class="relative">
  <!-- Geometria decorativa: arcos da marca (o "D" da logo) -->
  <div class="pointer-events-none absolute -top-24 -right-32 h-96 w-96 rounded-full border-[28px] border-brand-600/[0.07] dark:border-brand-500/[0.08]" aria-hidden="true"></div>
  <div class="pointer-events-none absolute top-40 -right-20 h-40 w-40 rounded-full border-[16px] border-brand-600/[0.05] dark:border-brand-500/[0.06]" aria-hidden="true"></div>

  <!-- Intro editorial -->
  <div class="hero-fade max-w-3xl pb-10 pt-4 sm:pt-8">
    <p class="eyebrow">Blog independente · Brasil</p>
    <h1 class="mt-4 font-display text-4xl sm:text-5xl lg:text-[3.4rem] font-extrabold leading-[1.05] tracking-tight text-ink-950 dark:text-white text-balance">
      Design, código, IA e games.{' '}
      <span class="bg-gradient-to-r from-brand-600 via-brand-500 to-brand-400 bg-clip-text text-transparent">Sem superficialidade.</span>
    </h1>
    <p class="mt-5 max-w-xl text-base sm:text-lg leading-relaxed text-ink-500 dark:text-ink-400">
      Análises com opinião, guias que vão direto ao ponto e cobertura do que realmente muda na sua rotina de trabalho e de jogo.
    </p>
    <div class="mt-7 flex flex-wrap items-center gap-3">
      <a href="/posts/" class="btn-primary">Explorar artigos <Icon name="arrow-right" class="h-4 w-4" /></a>
      <a href={`/category/${slugifyCategory(categories[0] ?? 'games')}/`} class="btn-ghost">Ver {categories[0] ?? 'Games'}</a>
    </div>
  </div>

  <!-- Bento grid -->
  {allPosts.length > 0 && (
    <div class="grid grid-cols-1 gap-5 lg:grid-cols-2">
      {mainPost && (
        <PostCard post={mainPost} variant="hero" class="reveal" loading="eager" fetchpriority="high" />
      )}

      <div class="flex flex-col gap-5">
        {sidePost1 && <PostCard post={sidePost1} variant="sidebar" class="reveal" loading="eager" />}

        <!-- Célula: tópicos -->
        <div class="reveal relative overflow-hidden rounded-2xl border border-ink-900/[0.07] bg-white p-5 shadow-card dark:border-white/[0.07] dark:bg-ink-900 dark:shadow-card-dark">
          <h2 class="font-display text-xs font-extrabold uppercase tracking-[0.2em] text-ink-400 dark:text-ink-500">Navegue por assunto</h2>
          <div class="mt-3 flex flex-wrap gap-2">
            {categories.map((cat) => (
              <a
                href={`/category/${slugifyCategory(cat)}/`}
                class="rounded-full border border-ink-900/10 px-3 py-1.5 text-xs font-semibold text-ink-600 transition-all duration-300 hover:-translate-y-0.5 hover:border-brand-600 hover:bg-brand-600 hover:text-white dark:border-white/10 dark:text-ink-300 dark:hover:border-brand-500 dark:hover:bg-brand-600"
              >
                {cat}
              </a>
            ))}
          </div>
        </div>
      </div>
    </div>
  )}
</section>
