---
import { slugifyCategory, normalizeCategoryLabel } from '../lib/blog';
import { SITE_ORIGIN, siteUrl } from '../lib/site';

interface Props {
  title?: string;
  description?: string;
  image?: any;
  canonicalUrl?: string;
  type?: string;
  pubDate?: Date | string;
  updatedDate?: Date | string;
  author?: string;
  category?: string;
}

const {
  title = 'Doug Design',
  description = 'Blog do Doug Design sobre Games, Tecnologia, IA e Programação',
  image = '/logo-doug-design-icone-puro.png',
  canonicalUrl = siteUrl(Astro.url.pathname),
  type = 'website',
  pubDate,
  updatedDate,
  author,
  category,
} = Astro.props;

const imageSrc = typeof image === 'string' ? image : (image && 'src' in image ? image.src : '/logo-doug-design-icone-puro.png');
const absoluteImageSrc = new URL(imageSrc, Astro.site || Astro.url.origin).href;
const formattedTitle = title === 'Doug Design' ? title : `${title} | Doug Design`;
const authorSlug = author?.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '').replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');

const isHome = Astro.url.pathname === '/';

// WebSite Schema (Homepage)
const websiteSchema = isHome ? {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "Doug Design",
  "url": SITE_ORIGIN,
  "potentialAction": {
    "@type": "SearchAction",
    "target": `${SITE_ORIGIN}/posts?search={search_term_string}`,
    "query-input": "required name=search_term_string"
  }
} : null;

// Organization Schema (Homepage)
const organizationSchema = isHome ? {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "Doug Design",
  "url": SITE_ORIGIN,
  "logo": siteUrl('/logo-doug-design.png'),
  "sameAs": [
    "https://github.com/dougkusanagi"
  ]
} : null;

// BreadcrumbList Schema
let breadcrumbSchema = null;
if (type === 'article' && category) {
  const categorySlug = slugifyCategory(category);
  breadcrumbSchema = {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Home",
        "item": SITE_ORIGIN
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": normalizeCategoryLabel(category),
        "item": siteUrl(`/category/${categorySlug}/`)
      },
      {
        "@type": "ListItem",
        "position": 3,
        "name": title,
        "item": canonicalUrl
      }
    ]
  };
} else if (Astro.url.pathname.startsWith('/category/') && category) {
  breadcrumbSchema = {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Home",
        "item": SITE_ORIGIN
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": normalizeCategoryLabel(category),
        "item": canonicalUrl
      }
    ]
  };
}
---

<!-- Basic Metadata -->
<title>{formattedTitle}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonicalUrl} />

<!-- OpenGraph / Facebook -->
<meta property="og:type" content={type} />
<meta property="og:url" content={canonicalUrl} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={absoluteImageSrc} />
<meta property="og:locale" content="pt_BR" />
<meta property="og:site_name" content="Doug Design" />

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:url" content={canonicalUrl} />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={absoluteImageSrc} />
<meta name="twitter:site" content="@dougkusanagi" />
<meta name="twitter:creator" content="@dougkusanagi" />

<!-- Structured Data (JSON-LD) -->
{websiteSchema && (
  <script type="application/ld+json" is:inline set:html={JSON.stringify(websiteSchema)} />
)}

{organizationSchema && (
  <script type="application/ld+json" is:inline set:html={JSON.stringify(organizationSchema)} />
)}

{breadcrumbSchema && (
  <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumbSchema)} />
)}

{type === 'article' && (
  <script type="application/ld+json" is:inline set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    "headline": title,
    "description": description,
    "image": [absoluteImageSrc],
    "datePublished": pubDate ? new Date(pubDate).toISOString() : undefined,
    "dateModified": updatedDate ? new Date(updatedDate).toISOString() : (pubDate ? new Date(pubDate).toISOString() : undefined),
    "author": {
      "@type": "Person",
      "name": author || "Doug Design",
      "url": authorSlug ? siteUrl(`/autores/${authorSlug}/`) : SITE_ORIGIN
    },
    "publisher": {
      "@type": "Organization",
      "name": "Doug Design",
      "logo": {
        "@type": "ImageObject",
        "url": siteUrl('/logo-doug-design.png')
      }
    },
    "mainEntityOfPage": {
      "@type": "WebPage",
      "@id": canonicalUrl
    },
    "articleSection": category,
    "inLanguage": "pt-BR",
    "isAccessibleForFree": true,
    "keywords": [category, author].filter(Boolean)
  })} />
)}
