---
import { getCollection } from 'astro:content';
import JobCard from './JobCard.astro';
import Icon from './Icon.astro';

const jobs = await getCollection('jobs', ({ data }) => data.active !== false);
const sortedJobs = jobs.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()).slice(0, 3);
---

<section class="reveal relative mt-16 overflow-hidden rounded-3xl border border-ink-900/[0.07] bg-white p-6 shadow-card md:p-8 dark:border-white/[0.07] dark:bg-ink-900 dark:shadow-card-dark">
  <!-- Arco decorativo da marca -->
  <div class="pointer-events-none absolute -right-16 -top-16 h-48 w-48 rounded-full border-[18px] border-brand-600/[0.06] dark:border-brand-500/[0.08]" aria-hidden="true"></div>

  <div class="relative mb-6 flex flex-col justify-between gap-4 border-b border-ink-900/[0.06] pb-5 md:flex-row md:items-center dark:border-white/[0.06]">
    <div>
      <p class="eyebrow">Oportunidades</p>
      <h2 class="mt-2 flex items-center gap-2 font-display text-xl font-extrabold tracking-tight text-ink-950 dark:text-white">
        Mural de Vagas e Serviços
      </h2>
      <p class="mt-1 text-xs text-ink-500 dark:text-ink-400">
        Encontre profissionais ou envie uma oportunidade de design, programação ou UI/UX.
      </p>
    </div>
    <button data-tally-open="b5gMJe" data-tally-emoji-text="👋" data-tally-emoji-animation="wave" class="btn-primary cursor-pointer border-none self-start">
      Anunciar Oportunidade
    </button>
  </div>

  <div class="relative grid grid-cols-1 gap-5 md:grid-cols-3">
    {sortedJobs.length > 0 ? (
      sortedJobs.map((job) => (
        <JobCard
          title={job.data.title}
          company={job.data.company}
          description={job.data.description}
          type={job.data.type}
          salary={job.data.salary}
          pubDate={job.data.pubDate}
          link={job.data.link}
        />
      ))
    ) : (
      <div class="col-span-full flex flex-col items-center justify-between gap-6 rounded-xl border border-dashed border-ink-300 p-6 md:flex-row md:p-8 dark:border-ink-600">
        <div class="max-w-2xl text-center md:text-left">
          <div class="mb-3 inline-flex items-center gap-2 rounded-full bg-brand-100 px-3 py-1 font-display text-[10px] font-bold text-brand-700 dark:bg-brand-900/40 dark:text-brand-300">
            <Icon name="briefcase" class="h-3.5 w-3.5" /> Espaço para Recrutadores
          </div>
          <h3 class="font-display text-lg font-extrabold leading-snug text-ink-950 md:text-xl dark:text-white">
            Quer contratar os melhores talentos de tecnologia e design?
          </h3>
          <p class="mt-2 text-xs leading-relaxed text-ink-500 md:text-sm dark:text-ink-400">
            Anuncie suas oportunidades diretamente em nossa homepage e alcance milhares de profissionais qualificados que visitam o blog diariamente.
          </p>
        </div>
        <button data-tally-open="b5gMJe" data-tally-emoji-text="👋" data-tally-emoji-animation="wave" class="btn-primary shrink-0 cursor-pointer border-none">
          Divulgar Vaga <Icon name="arrow-right" class="h-4 w-4" />
        </button>
      </div>
    )}
  </div>
</section>
