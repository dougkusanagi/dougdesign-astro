---
import { getPublishedPosts } from '../lib/blog';
import PostCard from './PostCard.astro';
import Newsletter from './Newsletter.astro';
import AdSense from './AdSense.astro';
import Icon from './Icon.astro';

const sortedPosts = await getPublishedPosts();

// Exclude the first 3 posts (which are displayed in the Hero section) and show at most 8 posts
const feedPosts = sortedPosts.slice(3, 11);
---

<div class="lg:col-span-2">
  <div class="mb-7 flex items-end justify-between">
    <div>
      <p class="eyebrow">Direto da forja</p>
      <h2 class="mt-2 font-display text-2xl font-extrabold tracking-tight text-ink-950 dark:text-white">Últimas Publicações</h2>
    </div>
    <a href="/posts/" class="group flex items-center gap-1.5 font-display text-xs font-bold uppercase tracking-wider text-brand-600 transition-colors hover:text-brand-500 dark:text-brand-400">
      Ver tudo
      <Icon name="arrow-right" class="h-3.5 w-3.5 transition-transform duration-300 group-hover:translate-x-1" />
    </a>
  </div>

  <div class="space-y-5">
    {feedPosts.map((post, index) => (
      <>
        <div class="reveal-fast">
          <PostCard post={post} variant="feed" />
        </div>

        {index === 1 && (
          <AdSense
            slot="8098120205"
            style="display:inline-block;width:100%;max-width:750px;height:238px"
            simulatedText="Google AdSense - Bloco In-Article (Display)"
            class="my-8 w-full"
          />
        )}

        {index === 3 && <Newsletter />}
      </>
    ))}
  </div>

  <AdSense
    slot="3980100424"
    format="auto"
    fullWidthResponsive={true}
    simulatedText="Google AdSense - Fim do Feed"
    class="my-8 w-full"
  />

  <div class="pt-8 text-center">
    <a href="/posts/" class="btn-ghost">
      Ver todas as publicações
      <Icon name="arrow-right" class="h-4 w-4" />
    </a>
  </div>
</div>
