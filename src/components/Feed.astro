---
import { getCollection } from 'astro:content';
import PostCard from './PostCard.astro';
import Newsletter from './Newsletter.astro';
import AdSense from './AdSense.astro';

// Fetch all posts and sort by date descending
const posts = await getCollection('blog', ({ data }) => !data.draft);
const sortedPosts = posts.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

// Exclude the first 3 posts (which are displayed in the Hero section)
const feedPosts = sortedPosts.slice(3);
---

<div class="lg:col-span-2 space-y-8 font-sans">
  <div class="flex items-center justify-between border-b border-slate-200 dark:border-zinc-800 pb-4">
    <h3 class="font-display font-extrabold text-2xl tracking-tight text-slate-900 dark:text-white">Últimas Publicações</h3>
    <a href="#" class="text-xs font-semibold text-brand-600 dark:text-brand-500 hover:underline">Ver tudo</a>
  </div>

  {feedPosts.map((post, index) => (
    <>
      <PostCard post={post} variant="feed" />
      
      {/* Insert newsletter inline after the 2nd post (index 1) */}
      {index === 1 && <Newsletter />}
      
      {/* Insert AdSense inline after the 4th post (index 3) */}
      {index === 3 && (
        <AdSense 
          slot="2345678901" 
          simulatedText="Google AdSense - Bloco Responsivo Inline Feed (Artigo/Display)" 
          class="my-8"
        />
      )}
    </>
  ))}
</div>
