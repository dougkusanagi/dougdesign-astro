---
interface Props {
  slot: string;
  layout?: string;
  format?: string;
  fullWidthResponsive?: boolean;
  class?: string;
  style?: string;
  simulatedText?: string;
}

const {
  slot,
  layout,
  format,
  fullWidthResponsive,
  class: className = '',
  style = 'display:block',
  simulatedText = 'Google AdSense'
} = Astro.props;

const isDev = import.meta.env.DEV;
---

<div class={`bg-white dark:bg-darkbg-900 border border-dashed border-slate-300 dark:border-slate-800 p-2 text-center text-[10px] text-slate-400 dark:text-zinc-500 rounded-lg ${className}`}>
  <div class="text-[9px] uppercase tracking-widest font-bold mb-1">Publicidade</div>
  
  <!-- Bloco AdSense Real (Sempre renderizado) -->
  <ins class="adsbygoogle"
       style={style}
       data-ad-client="ca-pub-5927498436558135"
       data-ad-slot={slot}
       {...(format ? { "data-ad-format": format } : {})}
       {...(fullWidthResponsive ? { "data-full-width-responsive": "true" } : {})}
       {...(layout ? { "data-layout": layout } : {})}></ins>
  
  {isDev && (
    <div class="mt-1 text-[8px] uppercase tracking-wider text-slate-400 dark:text-zinc-500 bg-slate-50 dark:bg-darkbg-950/30 py-1.5 rounded font-semibold">
      {simulatedText} (Slot: {slot})
    </div>
  )}
</div>

