---
import { getPublishedPosts } from '../lib/blog';
import PostCard from './PostCard.astro';
import Icon from './Icon.astro';

const allPosts = await getPublishedPosts();
const highlightSlugs = [
  'design-system-figma-avancado',
  'codigo-limpo-typescript-2026',
  'revolucao-npus-laptops-hibridos'
];

const highlights = allPosts.filter(post => highlightSlugs.includes(post.id));

const orderedHighlights = highlightSlugs
  .map(slug => highlights.find(p => p.id === slug))
  .filter(Boolean);
---

{orderedHighlights.length > 0 && (
  <section class="mt-20">
    <div class="mb-6 flex items-end justify-between">
      <div>
        <p class="eyebrow">Curadoria</p>
        <h2 class="mt-2 flex items-center gap-2.5 font-display text-2xl font-extrabold tracking-tight text-ink-950 dark:text-white">
          <span class="flex h-9 w-9 items-center justify-center rounded-xl bg-brand-600 text-white shadow-glow-sm">
            <Icon name="award" class="h-4.5 w-4.5" />
          </span>
          Destaques do Doug
        </h2>
      </div>
      <div class="flex items-center gap-2">
        <button id="destaques-prev" class="flex h-10 w-10 items-center justify-center rounded-full border border-ink-900/10 text-ink-500 transition-all duration-300 hover:border-brand-600 hover:bg-brand-600 hover:text-white disabled:opacity-30 disabled:pointer-events-none dark:border-white/10 dark:text-ink-400 cursor-pointer" aria-label="Anterior">
          <Icon name="chevron-left" class="h-4 w-4" />
        </button>
        <button id="destaques-next" class="flex h-10 w-10 items-center justify-center rounded-full border border-ink-900/10 text-ink-500 transition-all duration-300 hover:border-brand-600 hover:bg-brand-600 hover:text-white disabled:opacity-30 disabled:pointer-events-none dark:border-white/10 dark:text-ink-400 cursor-pointer" aria-label="Próximo">
          <Icon name="chevron-right" class="h-4 w-4" />
        </button>
      </div>
    </div>

    <div id="destaques-viewport" class="reveal overflow-hidden cursor-grab active:cursor-grabbing fade-x">
      <div class="flex gap-5">
        {orderedHighlights.map((post) => (
          <div class="flex-[0_0_85%] sm:flex-[0_0_46%] lg:flex-[0_0_31.8%] min-w-0">
            <PostCard post={post} variant="highlight" class="h-full" />
          </div>
        ))}
      </div>
    </div>
  </section>
)}

<script>
  import EmblaCarousel from 'embla-carousel';

  const setupDestaques = () => {
    const viewportNode = document.getElementById('destaques-viewport');
    const prevBtn = document.getElementById('destaques-prev');
    const nextBtn = document.getElementById('destaques-next');

    if (!viewportNode) return;

    const emblaApi = EmblaCarousel(viewportNode, {
      loop: false,
      align: 'start',
      containScroll: 'trimSnaps',
    });

    const updateButtons = () => {
      if (!emblaApi) return;
      prevBtn?.toggleAttribute('disabled', !emblaApi.canScrollPrev());
      nextBtn?.toggleAttribute('disabled', !emblaApi.canScrollNext());
    };

    prevBtn?.addEventListener('click', () => emblaApi.scrollPrev());
    nextBtn?.addEventListener('click', () => emblaApi.scrollNext());

    emblaApi.on('select', updateButtons);
    emblaApi.on('init', updateButtons);
    emblaApi.on('reInit', updateButtons);

    updateButtons();
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', setupDestaques, { once: true });
  } else {
    setupDestaques();
  }

  document.addEventListener('astro:page-load', setupDestaques);
</script>
