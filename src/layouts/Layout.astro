---
import SEO from '../components/SEO.astro';
import { Font } from 'astro:assets';
import { ClientRouter } from 'astro:transitions';
import SpeedInsights from '@vercel/speed-insights/astro';
import '../styles/global.css';
import TickerUrgente from '../components/TickerUrgente.astro';
import ConsentBanner from '../components/ConsentBanner.astro';
import AdBlockModal from '../components/AdBlockModal.astro';

interface Props {
  title?: string;
  description?: string;
  image?: any;
  canonicalUrl?: string;
  type?: string;
  pubDate?: Date | string;
  author?: string;
  enableClientRouter?: boolean;
}

const props = Astro.props;
const { enableClientRouter = false } = Astro.props;
---

<!doctype html>
<html lang="pt-BR" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/logo-doug-design-icone-puro.svg" />
		<link rel="icon" href="/favicon.ico" sizes="any" />
		<meta name="generator" content={Astro.generator} />
		
		<SEO {...props} />
		<Font cssVariable="--font-outfit" />
		<Font cssVariable="--font-plus-jakarta-sans" />
		{enableClientRouter && <ClientRouter />}

		<!-- WebMCP AI Agent tools registration -->
		<script is:inline>
			(function() {
				const modelContext = document.modelContext || navigator.modelContext;
				if (modelContext && typeof modelContext.registerTool === 'function') {
					try {
						modelContext.registerTool({
							name: "buscarArtigos",
							description: "Busca artigos no blog Doug Design sobre tecnologia, programação, games ou inteligência artificial.",
							inputSchema: {
								type: "object",
								properties: {
									query: {
										type: "string",
										description: "Termo de busca ou palavra-chave."
									}
								},
								required: ["query"]
							},
							execute: async (args) => {
								if (args && args.query) {
									window.location.href = `/posts?search=${encodeURIComponent(args.query)}`;
									return { success: true, message: `Buscando por: ${args.query}` };
								}
								return { success: false, message: "Query não fornecida." };
							}
						});
					} catch (e) {
						console.error("WebMCP Tool registration error:", e);
					}
				}
			})();
		</script>

		<script is:inline>
			(function() {
				var CONSENT_KEY = 'dougdesign-consent-v1';

				window.__doug = window.__doug || {};

				window.__doug.hasMarketingConsent = function() {
					return window.localStorage && (window.localStorage.getItem('dougdesign-analytics-consent-v1') || window.localStorage.getItem(CONSENT_KEY)) === 'accepted';
				};

				window.__doug.hasAdsConsent = function() {
					return window.localStorage && (window.localStorage.getItem('dougdesign-ads-consent-v1') || window.localStorage.getItem(CONSENT_KEY)) === 'accepted';
				};

				window.__doug.loadScriptOnce = function(id, src, attributes) {
					attributes = attributes || {};
					var existing = document.getElementById(id);
					if (existing) return Promise.resolve(existing);

					return new Promise(function(resolve, reject) {
						var script = document.createElement('script');
						script.id = id;
						script.src = src;
						script.async = true;

						Object.entries(attributes).forEach(function(entry) {
							var key = entry[0], value = entry[1];
							if (value === true) {
								script.setAttribute(key, '');
							} else if (value !== false && value != null) {
								script.setAttribute(key, String(value));
							}
						});

						script.onload = function() { resolve(script); };
						script.onerror = reject;
						document.head.appendChild(script);
					});
				};

				window.__doug.initAdsenseBlocks = function() {
					var ads = document.querySelectorAll('ins.adsbygoogle');
					ads.forEach(function(ad) {
						if (ad.dataset.adInitialized === 'true' || ad.childNodes.length > 0) return;
						ad.dataset.adInitialized = 'true';
						try {
							(window.adsbygoogle = window.adsbygoogle || []).push({});
						} catch (e) {}
					});
				};

				window.__doug.trackPageView = function() {
					if (typeof window.gtag !== 'function') return;
					var path = window.location.pathname + window.location.search;
					if (window.__doug.lastTrackedPath === path) return;
					window.__doug.lastTrackedPath = path;

					// Usando a recomendação oficial do Google Analytics para SPAs/ViewTransitions
					// Reconfigura o ID da tag atualizando page_path, page_location e page_title
					window.gtag('config', 'GT-WPDGLZ6', {
						page_title: document.title,
						page_location: window.location.href,
						page_path: window.location.pathname,
					});
				};

				window.__doug.trackEvent = function(name, params) {
					if (!window.__doug.hasMarketingConsent() || typeof window.gtag !== 'function') return;
					window.gtag('event', name, params || {});
				};

				window.__doug.initAdSense = function() {
					if (!window.__doug.hasAdsConsent()) return;
					if (window.__doug.adsenseLoading) return;
					window.__doug.adsenseLoading = true;
					window.__doug.loadScriptOnce(
						'adsbygoogle-script',
						'https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-5927498436558135',
						{ crossorigin: 'anonymous' }
					).then(function() {
						setTimeout(window.__doug.initAdsenseBlocks, 300);
					}).catch(function(e) {
						window.__doug.adsenseLoading = false;
						console.warn('AdSense load error:', e);
					});
				};

				// ─── Scripts de marketing/analytics: exigem consentimento explícito ───
				window.__doug.enableMarketing = async function() {
					if (window.__doug.marketingEnabled || !window.__doug.hasMarketingConsent()) return;
					window.__doug.marketingEnabled = true;

					// Load Tally and Google Tag Manager in parallel to avoid blocking analytics tracking
					window.__doug.loadScriptOnce('tally-widget-script', 'https://tally.so/widgets/embed.js').catch(function(e) {
						console.warn('Tally load error:', e);
					});

					window.__doug.loadScriptOnce('gtag-script', 'https://www.googletagmanager.com/gtag/js?id=GT-WPDGLZ6').then(function() {
						window.dataLayer = window.dataLayer || [];
						window.gtag = window.gtag || function(){window.dataLayer.push(arguments);};
						window.gtag('set', 'linker', { domains: ['dougdesign.com.br'] });
						window.gtag('js', new Date());
						window.gtag('set', 'developer_id.dZTNiMT', true);
						// Inicializa enviando o primeiro pageview explicitamente
						window.gtag('config', 'GT-WPDGLZ6', {
							page_title: document.title,
							page_location: window.location.href,
							page_path: window.location.pathname,
						});
						window.gtag('config', 'AW-5927498436558135');

						window.__doug.lastTrackedPath = window.location.pathname + window.location.search;
						if (!window.__doug.engagementTrackingReady) {
							window.__doug.engagementTrackingReady = true;
							var sent = {};
							window.addEventListener('scroll', function() {
								var height = document.documentElement.scrollHeight - window.innerHeight;
								if (!height) return;
								var percent = Math.floor((window.scrollY / height) * 100);
								[25, 50, 75, 90].forEach(function(mark) {
									if (percent >= mark && !sent[mark]) { sent[mark] = true; window.__doug.trackEvent('scroll_depth', { percent_scrolled: mark }); }
								});
							}, { passive: true });
						}
						if (!window.__doug.vitalsReady && 'PerformanceObserver' in window) {
							window.__doug.vitalsReady = true;
							var reportVital = function(name, value) { window.__doug.trackEvent('web_vital', { metric_name: name, metric_value: Math.round(value * 100) / 100 }); };
							try { new PerformanceObserver(function(list) { var entry = list.getEntries().pop(); if (entry) reportVital('LCP', entry.startTime); }).observe({ type: 'largest-contentful-paint', buffered: true }); } catch (e) {}
							try { new PerformanceObserver(function(list) { list.getEntries().forEach(function(entry) { if (!entry.hadRecentInput) reportVital('CLS', entry.value); }); }).observe({ type: 'layout-shift', buffered: true }); } catch (e) {}
							try { new PerformanceObserver(function(list) { var entry = list.getEntries().pop(); if (entry) reportVital('INP', entry.duration); }).observe({ type: 'event', buffered: true, durationThreshold: 40 }); } catch (e) {}
						}
					}).catch(function(e) {
						console.warn('gTag load error:', e);
					});
				};

				var bootMarketing = function() {
					if (!window.__doug.hasMarketingConsent()) return;
					window.__doug.enableMarketing();
				};

				// Inicializa o AdSense imediatamente (sem esperar consentimento)
				if (document.readyState === 'loading') {
					document.addEventListener('DOMContentLoaded', function() {
						window.__doug.initAdSense();
						bootMarketing();
					}, { once: true });
				} else {
					window.__doug.initAdSense();
					bootMarketing();
				}

				document.addEventListener('doug:consent-granted', bootMarketing);
				document.addEventListener('astro:page-load', function() {
					window.__doug.initAdSense();
					bootMarketing();
					if (window.__doug.hasMarketingConsent()) {
						window.__doug.trackPageView();
					}
					setTimeout(window.__doug.initAdsenseBlocks, 300);
				});
			})();
		</script>

		<!-- Theme Initial Script to avoid flash/FOUC -->
		<script is:inline>
			const applyTheme = () => {
				const theme = localStorage.getItem('theme') || 
					(!('theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
				if (theme === 'dark') {
					document.documentElement.classList.add('dark');
				} else {
					document.documentElement.classList.remove('dark');
				}
			};
			applyTheme();
			document.addEventListener('astro:after-swap', applyTheme);
		</script>
	</head>
	<body class="bg-slate-50 dark:bg-darkbg-950 text-slate-800 dark:text-zinc-200 transition-colors duration-300 pb-16 md:pb-0 font-sans">
		<TickerUrgente />
		<slot />
		<ConsentBanner />
		<AdBlockModal />
		<SpeedInsights />
	</body>
</html>
