---
import SEO from '../components/SEO.astro';
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  image?: any;
  type?: string;
  pubDate?: Date | string;
  author?: string;
}

const props = Astro.props;
---

<!doctype html>
<html lang="pt-BR" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/logo-doug-design.svg" />
		<meta name="generator" content={Astro.generator} />
		
		<SEO {...props} />
		<ClientRouter />

		<!-- Google Fonts Preconnect and Import -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700;800&family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />

		<!-- Google AdSense -->
		<script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-5927498436558135" crossorigin="anonymous"></script>
		<script is:inline>
			document.addEventListener('astro:page-load', () => {
				try {
					const ads = document.querySelectorAll('ins.adsbygoogle');
					ads.forEach(ad => {
						if (!ad.dataset.adInitialized) {
							ad.dataset.adInitialized = "true";
							(window.adsbygoogle = window.adsbygoogle || []).push({});
						}
					});
				} catch (e) {
					console.error('AdSense load error:', e);
				}
			});
		</script>

		<!-- Theme Initial Script to avoid flash/FOUC -->
		<script is:inline>
			const theme = localStorage.getItem('theme') || 
				(!('theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
			if (theme === 'dark') {
				document.documentElement.classList.add('dark');
			} else {
				document.documentElement.classList.remove('dark');
			}
		</script>
	</head>
	<body class="bg-slate-50 dark:bg-darkbg-950 text-slate-800 dark:text-zinc-200 transition-colors duration-300 pb-16 md:pb-0 font-sans">
		<slot />
	</body>
</html>
