---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PostCard from '../components/PostCard.astro';
import Icon from '../components/Icon.astro';

const posts = await getCollection('blog', ({ data }) => !data.draft);
const sortedPosts = posts.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
---

<Layout title="Todas as Publicações - Doug Design" description="Confira a lista completa de todos os artigos publicados no blog Doug Design sobre tecnologia, programação, games e inteligência artificial.">
  <Header />

  <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 font-sans">
    <!-- Voltar -->
    <a href="/" class="inline-flex items-center gap-1 text-slate-500 hover:text-brand-600 dark:text-zinc-400 dark:hover:text-brand-500 text-xs font-semibold uppercase tracking-wider mb-8 transition-colors font-display">
      <Icon name="chevron-left" class="w-4 h-4" /> Voltar para Home
    </a>

    <div class="border-b border-slate-200 dark:border-zinc-800 pb-4 mb-8">
      <h1 class="font-display font-extrabold text-3xl sm:text-4xl text-slate-900 dark:text-white">
        Todas as Publicações
      </h1>
      <p class="text-slate-500 dark:text-zinc-400 text-sm mt-2">
        {sortedPosts.length} artigos publicados no total.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
      {sortedPosts.map(post => (
        <PostCard post={post} variant="sidebar" />
      ))}
    </div>
  </main>

  <Footer />
</Layout>
