---
import type { GetStaticPaths } from 'astro';
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import PostCard from '../../components/PostCard.astro';
import Icon from '../../components/Icon.astro';
import LivePixWidget from '../../components/LivePixWidget.astro';
import AdSense from '../../components/AdSense.astro';
import { getPublishedPosts } from '../../lib/blog';

export const getStaticPaths = (async ({ paginate }) => {
  return paginate(await getPublishedPosts(), { pageSize: 12 });
}) satisfies GetStaticPaths;

const { page } = Astro.props;

const pillBase = 'category-pill rounded-full border px-4 py-2 text-xs font-bold transition-all duration-300 cursor-pointer';
const pillActive = 'border-brand-600 bg-brand-600 text-white shadow-glow-sm';
const pillIdle = 'border-ink-900/10 bg-white text-ink-600 hover:border-brand-500/50 hover:text-brand-600 hover:-translate-y-0.5 dark:border-white/10 dark:bg-ink-900 dark:text-ink-300 dark:hover:text-brand-300';

const categories = [
  { slug: 'all', label: 'Todos' },
  { slug: 'games', label: 'Games' },
  { slug: 'tecnologia', label: 'Tecnologia' },
  { slug: 'inteligencia-artificial', label: 'Inteligência Artificial' },
  { slug: 'programacao', label: 'Programação' },
  { slug: 'web-design', label: 'Web Design' },
  { slug: 'mobile', label: 'Mobile' },
  { slug: 'hardware', label: 'Hardware' },
  { slug: 'educacao', label: 'Educação' },
];
---

<Layout title={`Todas as Publicações - Página ${page.currentPage} - Doug Design`} description="Confira a lista completa de todos os artigos publicados no blog Doug Design sobre tecnologia, programação, games e inteligência artificial." prevUrl={page.url.prev} nextUrl={page.url.next}>
  <Header />

  <main class="mx-auto max-w-7xl px-4 py-10 sm:px-6 lg:px-8">
    <!-- Cabeçalho do arquivo -->
    <div class="relative mb-10 overflow-hidden rounded-3xl border border-ink-900/[0.07] bg-white p-7 shadow-card sm:p-10 dark:border-white/[0.07] dark:bg-ink-900 dark:shadow-card-dark">
      <div class="pointer-events-none absolute -right-20 -top-20 h-56 w-56 rounded-full border-[20px] border-brand-600/[0.06] dark:border-brand-500/[0.08]" aria-hidden="true"></div>

      <div class="relative flex flex-col justify-between gap-6 lg:flex-row lg:items-end">
        <div class="max-w-xl">
          <p class="eyebrow">Arquivo completo</p>
          <h1 class="mt-3 font-display text-3xl font-extrabold tracking-tight text-ink-950 sm:text-4xl dark:text-white text-balance">
            Todas as Publicações
          </h1>
          <p id="post-count-text" class="mt-3 text-sm text-ink-500 dark:text-ink-400">
            Página {page.currentPage} de {page.lastPage} — {page.total} artigos publicados no total.
          </p>
        </div>

        <!-- Busca com :has() focus ring -->
        <form
          toolname="buscarArtigos"
          tooldescription="Busca artigos no blog Doug Design sobre tecnologia, programação, games ou inteligência artificial."
          toolautosubmit="true"
          onsubmit="event.preventDefault();"
          class="search-shell relative w-full max-w-sm"
        >
          <input
            type="text"
            id="archive-search"
            name="query"
            placeholder="Buscar em todo o acervo..."
            class="w-full rounded-full border border-ink-900/10 bg-ink-50 py-3 pl-11 pr-4 text-sm text-ink-900 placeholder-ink-400 transition-all focus:outline-none dark:border-white/10 dark:bg-ink-950 dark:text-white"
          />
          <div class="pointer-events-none absolute left-4 top-3.5 text-ink-400">
            <Icon name="search" class="h-4 w-4" />
          </div>
        </form>
      </div>

      <!-- Pills de categoria -->
      <div id="category-pills" class="relative mt-7 flex flex-wrap gap-2">
        {categories.map((cat) => (
          <button
            data-category={cat.slug}
            class={`${pillBase} ${cat.slug === 'all' ? pillActive : pillIdle}`}
          >
            {cat.label}
          </button>
        ))}
      </div>
    </div>

    <AdSense
      slot="6543940190"
      format="auto"
      fullWidthResponsive={true}
      class="mb-10 w-full"
      simulatedText="AdSense - Topo Listagem"
    />

    <div id="posts-grid" class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {page.data.map((post, index) => (
        <>
          <div class="reveal-fast">
            <PostCard post={post} variant="sidebar" class="h-full" />
          </div>
          {index === 5 && (
            <div class="col-span-1 sm:col-span-2 lg:col-span-3">
              <AdSense
                slot="8098120205"
                format="auto"
                fullWidthResponsive={true}
                class="w-full"
                simulatedText="AdSense - Mid-Grid Listagem"
              />
            </div>
          )}
        </>
      ))}
    </div>

    <div id="search-empty-state" class="hidden py-20 text-center">
      <p class="font-display text-lg font-bold text-ink-400 dark:text-ink-500">Nenhum artigo encontrado.</p>
      <p class="mt-2 text-sm text-ink-400 dark:text-ink-500">Tente outro termo ou navegue pelas categorias.</p>
    </div>

    {page.lastPage > 1 && (
      <nav class="mt-14 flex items-center justify-between border-t border-ink-900/[0.07] pt-8 dark:border-white/[0.07]" aria-label="Paginação">
        <div>
          {page.url.prev && (
            <a href={page.url.prev} class="btn-ghost">
              <Icon name="chevron-left" class="h-4 w-4" /> Anterior
            </a>
          )}
        </div>
        <span class="font-display text-xs font-bold uppercase tracking-[0.2em] text-ink-400 dark:text-ink-500">
          {page.currentPage} / {page.lastPage}
        </span>
        <div>
          {page.url.next && (
            <a href={page.url.next} class="btn-ghost">
              Próxima <Icon name="chevron-right" class="h-4 w-4" />
            </a>
          )}
        </div>
      </nav>
    )}

    <LivePixWidget className="mt-12" />
  </main>

  <Footer />
</Layout>

<style>
  /* :has() — a casca da busca acende quando o campo recebe foco */
  .search-shell:has(input:focus) {
    filter: drop-shadow(0 0 18px oklch(0.6 0.2 258 / 0.35));
  }
  .search-shell input:focus {
    border-color: var(--color-brand-500);
    background: white;
  }
  .dark .search-shell input:focus {
    background: var(--color-ink-900);
  }
</style>

<script is:inline>
  const setupArchiveSearch = () => {
    const searchInput = document.getElementById('archive-search');
    const countText = document.getElementById('post-count-text');
    const grid = document.getElementById('posts-grid');
    const emptyState = document.getElementById('search-empty-state');

    if (!searchInput || !grid) return;

    const originalHtml = grid.innerHTML;
    const originalCountText = countText ? countText.textContent : '';

    const PILL_BASE = 'category-pill rounded-full border px-4 py-2 text-xs font-bold transition-all duration-300 cursor-pointer ';
    const PILL_ACTIVE = 'border-brand-600 bg-brand-600 text-white shadow-glow-sm';
    const PILL_IDLE = 'border-ink-900/10 bg-white text-ink-600 hover:border-brand-500/50 hover:text-brand-600 hover:-translate-y-0.5 dark:border-white/10 dark:bg-ink-900 dark:text-ink-300 dark:hover:text-brand-300';

    function renderCard(post) {
      const date = new Date(post.pubDate);
      const formattedDate = date.toLocaleDateString('pt-BR', { day: 'numeric', month: 'short', year: 'numeric' });
      return `
        <article class="card group relative flex h-full flex-col overflow-hidden rounded-2xl border border-ink-900/[0.07] bg-white shadow-card transition-all duration-500 hover:-translate-y-1.5 hover:shadow-glow dark:border-white/[0.07] dark:bg-ink-900 spotlight arc-border">
          <a href="/${post.slug}/" class="absolute inset-0 z-30" aria-label="${post.title}"></a>
          <div class="card-media relative shrink-0 overflow-hidden bg-ink-100 dark:bg-ink-950" style="aspect-ratio: 16 / 9;">
            <span class="absolute left-3 top-3 z-10 rounded-full bg-ink-950/70 px-2.5 py-1 font-display text-[9px] font-extrabold uppercase tracking-[0.16em] text-white backdrop-blur-md">${post.category}</span>
          </div>
          <div class="card-body flex flex-grow flex-col justify-between p-5">
            <div>
              <h3 class="font-display text-[15px] font-bold leading-snug tracking-tight text-ink-900 transition-colors duration-300 group-hover:text-brand-600 dark:text-white dark:group-hover:text-brand-300">${post.title}</h3>
              <p class="mt-2 text-xs leading-relaxed text-ink-500 line-clamp-2 dark:text-ink-400">${post.description}</p>
            </div>
            <div class="mt-4 flex items-center justify-between text-[11px] font-semibold text-ink-400 dark:text-ink-500">
              <span>${formattedDate}</span>
              <span class="flex h-7 w-7 items-center justify-center rounded-full border border-ink-900/10 text-ink-400 transition-all duration-500 group-hover:border-brand-600 group-hover:bg-brand-600 group-hover:text-white dark:border-white/10">
                <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14m-7-7 7 7-7 7"/></svg>
              </span>
            </div>
          </div>
        </article>
      `;
    }

    let activeCategory = 'all';

    async function doGlobalFilter() {
      const query = searchInput.value.toLowerCase().trim();

      if (query === '' && activeCategory === 'all') {
        grid.innerHTML = originalHtml;
        if (countText) countText.textContent = originalCountText;
        emptyState?.classList.add('hidden');
        return;
      }

      if (!window.__searchIndex) {
        try {
          const res = await fetch('/search-index.json');
          window.__searchIndex = await res.json();
        } catch (err) {
          console.error('Failed to load search index', err);
          return;
        }
      }

      const index = window.__searchIndex || [];

      const slugify = (text) => {
        return text.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '').replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '');
      };

      const matches = index.filter(post => {
        if (activeCategory !== 'all') {
          if (slugify(post.category) !== activeCategory) {
            return false;
          }
        }
        if (query !== '') {
          return (
            post.title.toLowerCase().includes(query) ||
            post.description.toLowerCase().includes(query) ||
            post.category.toLowerCase().includes(query)
          );
        }
        return true;
      });

      if (matches.length === 0) {
        grid.innerHTML = '';
        emptyState?.classList.remove('hidden');
      } else {
        emptyState?.classList.add('hidden');
        grid.innerHTML = matches.map(renderCard).join('');
      }

      if (countText) {
        countText.textContent = `${matches.length} ${matches.length === 1 ? 'artigo encontrado' : 'artigos encontrados'} em todo o blog.`;
      }
    }

    const categoryPills = document.querySelectorAll('.category-pill');
    categoryPills.forEach(pill => {
      pill.addEventListener('click', async (e) => {
        const target = e.currentTarget;
        activeCategory = target.getAttribute('data-category');

        categoryPills.forEach(p => { p.className = PILL_BASE + PILL_IDLE; });
        target.className = PILL_BASE + PILL_ACTIVE;

        await doGlobalFilter();
      });
    });

    searchInput.addEventListener('input', doGlobalFilter);

    const urlParams = new URLSearchParams(window.location.search);
    if (urlParams.get('search') === 'focus') {
      searchInput.focus();
    }
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', setupArchiveSearch, { once: true });
  } else {
    setupArchiveSearch();
  }

  document.addEventListener('astro:page-load', setupArchiveSearch);
</script>
