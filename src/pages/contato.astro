---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Icon from '../components/Icon.astro';
import LivePixWidget from '../components/LivePixWidget.astro';
---

<Layout title="Contato - Doug Design" description="Entre em contato com a equipe do Doug Design para parcerias, sugestões ou envio de vagas.">
  <Header />

  <main class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-12 font-sans">
    <div class="border-b border-slate-200 dark:border-zinc-800 pb-4 mb-8">
      <h1 class="font-display font-extrabold text-3xl sm:text-4xl text-slate-900 dark:text-white">
        Fale Conosco
      </h1>
      <p class="text-slate-500 dark:text-zinc-400 text-sm mt-2">
        Tem alguma sugestão, crítica ou quer divulgar uma vaga no nosso mural? Envie uma mensagem!
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <!-- Info Col -->
      <div class="md:col-span-1 space-y-6">
        <div>
          <h2 class="font-display font-bold text-xs uppercase tracking-wider text-slate-400 dark:text-zinc-500 mb-2">E-mail Direto</h2>
          <a href="mailto:contato@dougdesign.com.br" class="text-sm font-semibold text-brand-600 dark:text-brand-500 hover:underline">
            contato@dougdesign.com.br
          </a>
        </div>

        <div>
          <h2 class="font-display font-bold text-xs uppercase tracking-wider text-slate-400 dark:text-zinc-500 mb-2">Redes Sociais</h2>
          <div class="flex gap-3 text-slate-600 dark:text-zinc-400">
            <a href="https://github.com/dougkusanagi" target="_blank" rel="noopener noreferrer" class="hover:text-brand-600 transition-colors flex items-center gap-1">
              <Icon name="github" class="w-4 h-4" /> GitHub
            </a>
          </div>
        </div>
      </div>

      <!-- Form Col -->
      <div class="md:col-span-2 bg-white dark:bg-darkbg-900 rounded-xl p-6 border border-slate-200/60 dark:border-slate-800/60 shadow-sm">
        <div class="space-y-4">
          <p class="text-sm leading-relaxed text-slate-600 dark:text-zinc-300">
            O envio automático está sendo integrado. Para garantir que sua mensagem chegue de verdade, use o e-mail direto abaixo.
          </p>
          <a
            href="mailto:contato@dougdesign.com.br?subject=Contato%20Doug%20Design"
            class="inline-flex w-full items-center justify-center rounded-lg bg-brand-600 py-2.5 text-xs font-bold uppercase tracking-wider text-white shadow-md transition-all hover:bg-brand-500 font-display"
          >
            Abrir e-mail de contato
          </a>
        </div>
      </div>
    </div>

    <!-- LivePix Sponsor -->
    <LivePixWidget className="mt-12" />
  </main>

  <Footer />
</Layout>
