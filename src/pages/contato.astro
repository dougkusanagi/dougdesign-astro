---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Icon from '../components/Icon.astro';
---

<Layout title="Contato - Doug Design" description="Entre em contato com a equipe do Doug Design para parcerias, sugestões ou envio de vagas.">
  <Header />

  <main class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-12 font-sans">
    <div class="border-b border-slate-200 dark:border-zinc-800 pb-4 mb-8">
      <h1 class="font-display font-extrabold text-3xl sm:text-4xl text-slate-900 dark:text-white">
        Fale Conosco
      </h1>
      <p class="text-slate-500 dark:text-zinc-400 text-sm mt-2">
        Tem alguma sugestão, crítica ou quer divulgar uma vaga no nosso mural? Envie uma mensagem!
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <!-- Info Col -->
      <div class="md:col-span-1 space-y-6">
        <div>
          <h3 class="font-display font-bold text-xs uppercase tracking-wider text-slate-400 dark:text-zinc-500 mb-2">E-mail Direto</h3>
          <a href="mailto:contato@dougdesign.com.br" class="text-sm font-semibold text-brand-600 dark:text-brand-500 hover:underline">
            contato@dougdesign.com.br
          </a>
        </div>

        <div>
          <h3 class="font-display font-bold text-xs uppercase tracking-wider text-slate-400 dark:text-zinc-500 mb-2">Redes Sociais</h3>
          <div class="flex gap-3 text-slate-600 dark:text-zinc-400">
            <a href="https://github.com/dougkusanagi" target="_blank" rel="noopener noreferrer" class="hover:text-brand-600 transition-colors flex items-center gap-1">
              <Icon name="github" class="w-4 h-4" /> GitHub
            </a>
          </div>
        </div>
      </div>

      <!-- Form Col -->
      <div class="md:col-span-2 bg-white dark:bg-darkbg-900 rounded-xl p-6 border border-slate-200/60 dark:border-slate-800/60 shadow-sm">
        <form id="contact-form" class="space-y-4" onsubmit="event.preventDefault(); document.getElementById('contact-form').style.display='none'; document.getElementById('success-message').style.display='block';">
          <div>
            <label for="name" class="block text-xs font-bold text-slate-700 dark:text-zinc-300 uppercase tracking-wider mb-1">Nome</label>
            <input type="text" id="name" required class="w-full bg-slate-50 dark:bg-darkbg-950 border border-slate-200 dark:border-slate-800 rounded-lg px-3 py-2 text-xs focus:outline-none focus:ring-1 focus:ring-brand-500 text-slate-900 dark:text-white" />
          </div>

          <div>
            <label for="email" class="block text-xs font-bold text-slate-700 dark:text-zinc-300 uppercase tracking-wider mb-1">E-mail</label>
            <input type="email" id="email" required class="w-full bg-slate-50 dark:bg-darkbg-950 border border-slate-200 dark:border-slate-800 rounded-lg px-3 py-2 text-xs focus:outline-none focus:ring-1 focus:ring-brand-500 text-slate-900 dark:text-white" />
          </div>

          <div>
            <label for="message" class="block text-xs font-bold text-slate-700 dark:text-zinc-300 uppercase tracking-wider mb-1">Mensagem</label>
            <textarea id="message" rows="4" required class="w-full bg-slate-50 dark:bg-darkbg-950 border border-slate-200 dark:border-slate-800 rounded-lg px-3 py-2 text-xs focus:outline-none focus:ring-1 focus:ring-brand-500 text-slate-900 dark:text-white"></textarea>
          </div>

          <button type="submit" class="w-full bg-brand-600 hover:bg-brand-500 text-white font-bold text-xs uppercase tracking-wider py-2.5 rounded-lg shadow-md transition-all font-display">
            Enviar Mensagem
          </button>
        </form>

        <div id="success-message" class="hidden text-center py-8">
          <div class="w-12 h-12 bg-emerald-100 dark:bg-emerald-900/30 text-emerald-600 dark:text-emerald-400 rounded-full flex items-center justify-center mx-auto mb-4">
            <Icon name="check" class="w-6 h-6" />
          </div>
          <h3 class="font-display font-bold text-base text-slate-900 dark:text-white mb-1">Mensagem Enviada!</h3>
          <p class="text-xs text-slate-500 dark:text-zinc-400">Obrigado pelo contato. Retornaremos o quanto antes.</p>
        </div>
      </div>
    </div>
  </main>

  <Footer />
</Layout>
