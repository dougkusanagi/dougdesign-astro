---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Icon from '../components/Icon.astro';
import LivePixWidget from '../components/LivePixWidget.astro';
---

<Layout title="Contato - Doug Design" description="Entre em contato com a equipe do Doug Design para parcerias, sugestões ou envio de vagas.">
  <Header />

  <main class="mx-auto max-w-5xl px-4 py-12 sm:px-6 lg:px-8">
    <div class="mb-12 max-w-2xl">
      <p class="eyebrow">Contato</p>
      <h1 class="mt-3 font-display text-4xl font-extrabold tracking-tight text-ink-950 sm:text-5xl dark:text-white text-balance">
        Fale com a gente<span class="text-brand-600">.</span>
      </h1>
      <p class="mt-4 text-base leading-relaxed text-ink-500 dark:text-ink-400">
        Sugestão de pauta, parceria, correção ou vaga para o mural — toda mensagem é lida por um humano.
      </p>
    </div>

    <div class="grid grid-cols-1 gap-8 md:grid-cols-3">
      <!-- Info -->
      <div class="space-y-4 md:col-span-1">
        <a href="mailto:contato@dougdesign.com.br" class="group block rounded-2xl border border-ink-900/[0.07] bg-white p-6 shadow-card transition-all duration-300 hover:-translate-y-1 hover:shadow-glow dark:border-white/[0.07] dark:bg-ink-900 dark:shadow-card-dark spotlight">
          <span class="flex h-10 w-10 items-center justify-center rounded-xl bg-brand-600 text-white shadow-glow-sm">
            <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
          </span>
          <h2 class="mt-4 font-display text-xs font-extrabold uppercase tracking-[0.18em] text-ink-400 dark:text-ink-500">E-mail direto</h2>
          <p class="mt-1 text-sm font-bold text-ink-900 group-hover:text-brand-600 transition-colors dark:text-white">contato@dougdesign.com.br</p>
        </a>

        <div class="rounded-2xl border border-ink-900/[0.07] bg-white p-6 shadow-card dark:border-white/[0.07] dark:bg-ink-900 dark:shadow-card-dark">
          <span class="flex h-10 w-10 items-center justify-center rounded-xl bg-ink-900 text-white dark:bg-white dark:text-ink-900">
            <Icon name="briefcase" class="h-5 w-5" />
          </span>
          <h2 class="mt-4 font-display text-xs font-extrabold uppercase tracking-[0.18em] text-ink-400 dark:text-ink-500">Vagas e serviços</h2>
          <p class="mt-1 text-sm leading-relaxed text-ink-600 dark:text-ink-300">Use o formulário ao lado para anunciar no nosso mural de oportunidades.</p>
        </div>

        <div class="rounded-2xl border border-ink-900/[0.07] bg-white p-6 shadow-card dark:border-white/[0.07] dark:bg-ink-900 dark:shadow-card-dark">
          <h2 class="font-display text-xs font-extrabold uppercase tracking-[0.18em] text-ink-400 dark:text-ink-500">Redes</h2>
          <a href="https://github.com/dougkusanagi" target="_blank" rel="noopener noreferrer" class="mt-3 inline-flex items-center gap-2 text-sm font-bold text-ink-900 transition-colors hover:text-brand-600 dark:text-white dark:hover:text-brand-400">
            GitHub <Icon name="external-link" class="h-3.5 w-3.5" />
          </a>
        </div>
      </div>

      <!-- Form -->
      <div class="rounded-3xl border border-ink-900/[0.07] bg-white p-7 shadow-card sm:p-8 md:col-span-2 dark:border-white/[0.07] dark:bg-ink-900 dark:shadow-card-dark">
        <form
          id="contact-form"
          toolname="enviarMensagemContato"
          tooldescription="Envia uma mensagem de contato para a equipe do Doug Design especificando nome, e-mail e texto da mensagem."
          toolautosubmit="true"
          class="space-y-5"
          onsubmit="event.preventDefault(); document.getElementById('contact-form').style.display='none'; document.getElementById('success-message').style.display='block';"
        >
          <div class="grid grid-cols-1 gap-5 sm:grid-cols-2">
            <div>
              <label for="name" class="mb-2 block font-display text-[11px] font-extrabold uppercase tracking-[0.16em] text-ink-500 dark:text-ink-400">Nome</label>
              <input type="text" id="name" name="name" required class="field w-full rounded-xl border border-ink-900/10 bg-ink-50 px-4 py-3 text-sm text-ink-900 transition-all focus:border-brand-500 focus:outline-none focus:ring-4 focus:ring-brand-500/15 dark:border-white/10 dark:bg-ink-950 dark:text-white" placeholder="Seu nome" />
            </div>
            <div>
              <label for="email" class="mb-2 block font-display text-[11px] font-extrabold uppercase tracking-[0.16em] text-ink-500 dark:text-ink-400">E-mail</label>
              <input type="email" id="email" name="email" required class="field w-full rounded-xl border border-ink-900/10 bg-ink-50 px-4 py-3 text-sm text-ink-900 transition-all focus:border-brand-500 focus:outline-none focus:ring-4 focus:ring-brand-500/15 dark:border-white/10 dark:bg-ink-950 dark:text-white" placeholder="seu@email.com" />
            </div>
          </div>

          <div>
            <label for="message" class="mb-2 block font-display text-[11px] font-extrabold uppercase tracking-[0.16em] text-ink-500 dark:text-ink-400">Mensagem</label>
            <textarea id="message" name="message" rows="5" required class="field w-full rounded-xl border border-ink-900/10 bg-ink-50 px-4 py-3 text-sm text-ink-900 transition-all focus:border-brand-500 focus:outline-none focus:ring-4 focus:ring-brand-500/15 dark:border-white/10 dark:bg-ink-950 dark:text-white" placeholder="Como podemos ajudar?"></textarea>
          </div>

          <button type="submit" class="btn-primary w-full justify-center !py-3.5 cursor-pointer border-none">
            Enviar Mensagem
          </button>
        </form>

        <div id="success-message" class="hidden py-10 text-center">
          <div class="mx-auto mb-5 flex h-14 w-14 items-center justify-center rounded-full bg-emerald-100 text-emerald-600 dark:bg-emerald-900/30 dark:text-emerald-400">
            <svg class="h-7 w-7" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
          </div>
          <h2 class="font-display text-lg font-extrabold text-ink-950 dark:text-white">Mensagem enviada!</h2>
          <p class="mt-2 text-sm text-ink-500 dark:text-ink-400">Obrigado pelo contato. Retornaremos o quanto antes.</p>
        </div>
      </div>
    </div>

    <LivePixWidget className="mt-14" />
  </main>

  <Footer />
</Layout>
