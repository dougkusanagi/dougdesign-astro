---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

// Load markdown files from the docs/components/ folder using Vite glob
const componentDocsGlob = import.meta.glob('../../../docs/components/*.md', { eager: true });

// Extract component details for list and search
const componentsList = Object.entries(componentDocsGlob).map(([filePath, doc]: [string, any]) => {
  const fileParts = filePath.split(/[/\\]/);
  const fileName = fileParts[fileParts.length - 1];
  const name = fileName.replace('.md', '');
  return {
    name,
    title: doc.frontmatter?.title || name,
    Content: doc.default
  };
});
---

<Layout title="Documentação de Componentes | Doug Design">
  <Header />

  <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10 min-h-screen">
    <div class="lg:flex lg:gap-8">
      
      <!-- Sidebar Navigation -->
      <aside class="lg:w-64 flex-shrink-0 mb-8 lg:mb-0">
        <div class="sticky top-20 bg-white dark:bg-zinc-950 p-6 rounded-2xl border border-slate-200 dark:border-zinc-800 shadow-sm">
          <h2 class="text-sm font-semibold text-slate-400 uppercase tracking-wider mb-4">Componentes</h2>
          
          <!-- Search Box -->
          <div class="mb-4">
            <input 
              type="text" 
              id="component-search" 
              placeholder="Filtrar..." 
              class="w-full px-3 py-1.5 text-xs rounded-lg border border-slate-200 dark:border-zinc-800 bg-slate-50 dark:bg-zinc-900 text-slate-800 dark:text-zinc-200 focus:outline-none focus:ring-1 focus:ring-brand-500"
            />
          </div>

          <nav class="space-y-1" id="components-nav">
            {componentsList.map((comp, idx) => (
              <a 
                href={`#${comp.name}`} 
                data-name={comp.name.toLowerCase()}
                class={`block px-3 py-2 text-sm font-medium rounded-lg transition-colors ${idx === 0 ? 'bg-brand-50 text-brand-600 dark:bg-brand-950/30 dark:text-brand-400' : 'text-slate-600 dark:text-zinc-400 hover:bg-slate-50 dark:hover:bg-zinc-900'}`}
                onclick={`setActiveTab('${comp.name}')`}
              >
                {comp.name}
              </a>
            ))}
          </nav>
        </div>
      </aside>

      <!-- Content Area -->
      <section class="flex-1">
        <div class="bg-white dark:bg-zinc-950 p-8 rounded-2xl border border-slate-200 dark:border-zinc-800 shadow-sm">
          
          {componentsList.map((comp, idx) => (
            <div 
              id={`section-${comp.name}`} 
              class={`component-section space-y-6 ${idx === 0 ? '' : 'hidden'}`}
            >
              <article class="prose dark:prose-invert max-w-none prose-slate prose-headings:font-display dark:prose-headings:text-white dark:text-zinc-300">
                <comp.Content />
              </article>
            </div>
          ))}

        </div>
      </section>

    </div>
  </main>

  <Footer />
</Layout>

<script is:inline>
  // Simple client-side navigation and filtering
  function setActiveTab(compName) {
    // Hide all sections
    const sections = document.querySelectorAll('.component-section');
    sections.forEach(sec => sec.classList.add('hidden'));

    // Show selected section
    const targetSection = document.getElementById(`section-${compName}`);
    if (targetSection) {
      targetSection.classList.remove('hidden');
    }

    // Update active nav link style
    const navLinks = document.querySelectorAll('#components-nav a');
    navLinks.forEach(link => {
      if (link.getAttribute('href') === `#${compName}`) {
        link.className = 'block px-3 py-2 text-sm font-medium rounded-lg bg-brand-50 text-brand-600 dark:bg-brand-950/30 dark:text-brand-400';
      } else {
        link.className = 'block px-3 py-2 text-sm font-medium rounded-lg text-slate-600 dark:text-zinc-400 hover:bg-slate-50 dark:hover:bg-zinc-900';
      }
    });
  }

  // Handle URL hash on initial load
  window.addEventListener('DOMContentLoaded', () => {
    const hash = window.location.hash.substring(1);
    if (hash) {
      setActiveTab(hash);
    }

    // Search filter execution
    const searchInput = document.getElementById('component-search');
    if (searchInput) {
      searchInput.addEventListener('input', (e) => {
        const query = e.target.value.toLowerCase();
        const links = document.querySelectorAll('#components-nav a');
        links.forEach(link => {
          const name = link.getAttribute('data-name');
          if (name.includes(query)) {
            link.classList.remove('hidden');
          } else {
            link.classList.add('hidden');
          }
        });
      });
    }
  });
</script>
