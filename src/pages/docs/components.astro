---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

// Load markdown files from the docs/components/ folder using Vite glob
const componentDocsGlob = import.meta.glob('../../../docs/components/*.md', { eager: true });

// Extract component details for list and search
const componentsList = Object.entries(componentDocsGlob).map(([filePath, doc]: [string, any]) => {
  const fileParts = filePath.split(/[/\\]/);
  const fileName = fileParts[fileParts.length - 1];
  const name = fileName.replace('.md', '');
  return {
    name,
    title: doc.frontmatter?.title || name,
    Content: doc.default
  };
});
---

<Layout title="Documentação de Componentes | Doug Design">
  <Header />

  <main class="mx-auto min-h-screen max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    <div class="mb-10">
      <p class="eyebrow">Interno</p>
      <h1 class="mt-3 font-display text-3xl font-extrabold tracking-tight text-ink-950 sm:text-4xl dark:text-white text-balance">
        Documentação de Componentes<span class="text-brand-600">.</span>
      </h1>
    </div>

    <div class="lg:flex lg:gap-8">

      <!-- Sidebar Navigation -->
      <aside class="mb-8 flex-shrink-0 lg:mb-0 lg:w-64">
        <div class="sticky top-24 rounded-2xl border border-ink-900/[0.07] bg-white p-5 shadow-card dark:border-white/[0.07] dark:bg-ink-900 dark:shadow-card-dark">
          <h2 class="mb-4 font-display text-[11px] font-extrabold uppercase tracking-[0.2em] text-ink-400 dark:text-ink-500">Componentes</h2>

          <!-- Search Box -->
          <div class="mb-4">
            <input
              type="text"
              id="component-search"
              placeholder="Filtrar..."
              class="w-full rounded-full border border-ink-900/10 bg-ink-50 px-4 py-2 text-xs text-ink-900 transition-all focus:border-brand-500 focus:outline-none focus:ring-4 focus:ring-brand-500/15 dark:border-white/10 dark:bg-ink-950 dark:text-white"
            />
          </div>

          <nav class="space-y-1" id="components-nav">
            {componentsList.map((comp, idx) => (
              <a
                href={`#${comp.name}`}
                data-name={comp.name.toLowerCase()}
                class={`block rounded-lg px-3 py-2 text-sm font-semibold transition-colors ${idx === 0 ? 'bg-brand-600 text-white shadow-glow-sm' : 'text-ink-600 hover:bg-brand-600/[0.07] hover:text-brand-600 dark:text-ink-300 dark:hover:text-brand-300'}`}
                onclick={`setActiveTab('${comp.name}')`}
              >
                {comp.name}
              </a>
            ))}
          </nav>
        </div>
      </aside>

      <!-- Content Area -->
      <section class="flex-1">
        <div class="rounded-2xl border border-ink-900/[0.07] bg-white p-8 shadow-card dark:border-white/[0.07] dark:bg-ink-900 dark:shadow-card-dark">

          {componentsList.map((comp, idx) => (
            <div
              id={`section-${comp.name}`}
              class={`component-section space-y-6 ${idx === 0 ? '' : 'hidden'}`}
            >
              <article class="prose max-w-none">
                <comp.Content />
              </article>
            </div>
          ))}

        </div>
      </section>

    </div>
  </main>

  <Footer />
</Layout>

<script is:inline>
  // Simple client-side navigation and filtering
  function setActiveTab(compName) {
    // Hide all sections
    const sections = document.querySelectorAll('.component-section');
    sections.forEach(sec => sec.classList.add('hidden'));

    // Show selected section
    const targetSection = document.getElementById(`section-${compName}`);
    if (targetSection) {
      targetSection.classList.remove('hidden');
    }

    // Update active nav link style
    const navLinks = document.querySelectorAll('#components-nav a');
    navLinks.forEach(link => {
      if (link.getAttribute('href') === `#${compName}`) {
        link.className = 'block rounded-lg px-3 py-2 text-sm font-semibold transition-colors bg-brand-600 text-white shadow-glow-sm';
      } else {
        link.className = 'block rounded-lg px-3 py-2 text-sm font-semibold transition-colors text-ink-600 hover:bg-brand-600/[0.07] hover:text-brand-600 dark:text-ink-300 dark:hover:text-brand-300';
      }
    });
  }

  // Handle URL hash on initial load
  window.addEventListener('DOMContentLoaded', () => {
    const hash = window.location.hash.substring(1);
    if (hash) {
      setActiveTab(hash);
    }

    // Search filter execution
    const searchInput = document.getElementById('component-search');
    if (searchInput) {
      searchInput.addEventListener('input', (e) => {
        const query = e.target.value.toLowerCase();
        const links = document.querySelectorAll('#components-nav a');
        links.forEach(link => {
          const name = link.getAttribute('data-name');
          if (name.includes(query)) {
            link.classList.remove('hidden');
          } else {
            link.classList.add('hidden');
          }
        });
      });
    }
  });
</script>
