---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import PostCard from '../../components/PostCard.astro';
import Icon from '../../components/Icon.astro';
import LivePixWidget from '../../components/LivePixWidget.astro';
import AdSense from '../../components/AdSense.astro';
import { getPublishedPosts, normalizeCategoryLabel, slugifyCategory } from '../../lib/blog';

export async function getStaticPaths() {
  const posts = await getPublishedPosts();
  const grouped = new Map<string, typeof posts>();

  for (const post of posts) {
    const categorySlug = slugifyCategory(normalizeCategoryLabel(post.data.category));
    const existing = grouped.get(categorySlug) ?? [];
    existing.push(post);
    grouped.set(categorySlug, existing);
  }

  return [...grouped.entries()].map(([categorySlug, categoryPosts]) => ({
    params: { category: categorySlug },
    props: {
      categoryName: normalizeCategoryLabel(categoryPosts[0].data.category),
      posts: categoryPosts,
    },
  }));
}

const { categoryName, posts } = Astro.props;
const sortedPosts = posts.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
const itemListSchema = {
  '@context': 'https://schema.org', '@type': 'ItemList', name: categoryName,
  itemListElement: sortedPosts.slice(0, 50).map((post, index) => ({ '@type': 'ListItem', position: index + 1, name: post.data.title, url: `https://dougdesign.com.br/${post.data.slug || post.id}/` })),
};

const featured = sortedPosts[0];
const rest = sortedPosts.slice(1);
---

<Layout title={`Categoria: ${categoryName} - Doug Design`} description={`Confira todos os artigos publicados sob a categoria ${categoryName}.`} category={categoryName}>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(itemListSchema)} />
  <Header />

  <main class="mx-auto max-w-7xl px-4 py-10 sm:px-6 lg:px-8">
    <!-- Cabeçalho da categoria -->
    <div class="relative mb-10 overflow-hidden rounded-3xl bg-ink-950 p-7 text-white sm:p-10">
      <div class="pointer-events-none absolute -left-16 -bottom-24 h-64 w-64 rounded-full bg-brand-600/25 blur-[90px]" aria-hidden="true"></div>
      <div class="pointer-events-none absolute -right-10 -top-16 h-52 w-52 rounded-full border-[18px] border-brand-600/15" aria-hidden="true"></div>

      <div class="relative">
        <nav class="flex items-center gap-2 text-[11px] font-bold uppercase tracking-[0.16em] text-white/50" aria-label="Trilha">
          <a href="/" class="transition-colors hover:text-white">Home</a>
          <span>/</span>
          <span class="text-brand-400">Categoria</span>
        </nav>
        <h1 class="mt-4 font-display text-4xl font-extrabold tracking-tight text-balance sm:text-5xl">
          {categoryName}<span class="text-brand-500">.</span>
        </h1>
        <p class="mt-3 max-w-lg text-sm leading-relaxed text-white/60">
          {posts.length} {posts.length === 1 ? 'artigo publicado' : 'artigos publicados'} — análises, guias e notícias com a profundidade de sempre.
        </p>
      </div>
    </div>

    <AdSense
      slot="6543940190"
      format="auto"
      fullWidthResponsive={true}
      class="mb-10 w-full"
      simulatedText="AdSense - Topo Categoria"
    />

    {sortedPosts.length > 0 ? (
      <>
        {/* Post em destaque da categoria */}
        {featured && (
          <div class="reveal mb-8">
            <PostCard post={featured} variant="hero" loading="eager" />
          </div>
        )}

        <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {rest.map((post, index) => (
            <>
              <div class="reveal-fast">
                <PostCard post={post} variant="sidebar" class="h-full" />
              </div>
              {index === 2 && (
                <div class="col-span-1 sm:col-span-2 lg:col-span-3">
                  <AdSense
                    slot="8098120205"
                    format="auto"
                    fullWidthResponsive={true}
                    class="w-full"
                    simulatedText="AdSense - Mid-Grid Categoria"
                  />
                </div>
              )}
            </>
          ))}
        </div>
      </>
    ) : (
      <div class="py-16 text-center">
        <p class="text-ink-500 dark:text-ink-400">Nenhum post publicado nesta categoria por enquanto.</p>
      </div>
    )}

    <LivePixWidget className="mt-14" />
  </main>

  <Footer />
</Layout>
