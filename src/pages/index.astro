---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import AdSense from '../components/AdSense.astro';
import Hero from '../components/Hero.astro';
import MuralJobs from '../components/MuralJobs.astro';
import Destaques from '../components/Destaques.astro';
import Feed from '../components/Feed.astro';
import Sidebar from '../components/Sidebar.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Doug Design | Desenvolvimento, Web Design, IA e Games" description="Blog brasileiro com guias práticos sobre web design, IA, programação, tecnologia e games.">
  <Header />

  <!-- ADSENSE: banner sob o header -->
  <div class="mx-auto mt-4 max-w-7xl px-4 sm:px-6 lg:px-8">
    <AdSense
      slot="6543940190"
      format="auto"
      fullWidthResponsive={true}
      simulatedText="Google AdSense - Banner Topo Responsivo (728x90 / 970x90)"
      class="w-full min-h-[100px]"
    />
  </div>

  <main class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
    <Hero />
  </main>

  <!-- Faixa marquee de tópicos (100% CSS) -->
  <div class="marquee-mask mt-6 overflow-hidden border-y border-ink-900/[0.06] py-4 dark:border-white/[0.06]" aria-hidden="true">
    <div class="marquee items-center gap-12" style="animation-duration: 46s">
      {[...Array(2)].map(() => (
        <div class="flex shrink-0 items-center gap-12">
          {['Web Design', 'Programação', 'Inteligência Artificial', 'Games', 'Tecnologia', 'Mobile', 'Hardware', 'Educação'].map((topic) => (
            <span class="flex shrink-0 items-center gap-12">
              <span class="font-display text-lg font-extrabold uppercase tracking-[0.2em] text-ink-300 dark:text-ink-600">{topic}</span>
              <span class="h-2 w-2 rotate-45 bg-brand-600"></span>
            </span>
          ))}
        </div>
      ))}
    </div>
  </div>

  <main class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <MuralJobs />
    <Destaques />

    <!-- ADSENSE: entre Destaques e Feed -->
    <div class="mt-12">
      <AdSense
        slot="8098120205"
        format="auto"
        fullWidthResponsive={true}
        class="w-full"
        simulatedText="AdSense - Entre Destaques e Feed"
      />
    </div>

    <section class="mt-16 grid grid-cols-1 gap-10 lg:grid-cols-3">
      <Feed />
      <Sidebar />
    </section>
  </main>

  <Footer />
</Layout>
