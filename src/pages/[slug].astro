---
import { render } from 'astro:content';
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Icon from '../components/Icon.astro';
import LivePixWidget from '../components/LivePixWidget.astro';
import GiscusComments from '../components/GiscusComments.astro';
import { getPostSlug, getPublishedPosts, normalizeCategoryLabel, slugifyCategory } from '../lib/blog';
import AdSense from '../components/AdSense.astro';
import ReadingProgressBar from '../components/ReadingProgressBar.astro';
import Newsletter from '../components/Newsletter.astro';

export async function getStaticPaths() {
  const posts = await getPublishedPosts();
  return posts.map(post => ({
    params: { slug: getPostSlug(post) },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const formattedDate = new Date(post.data.pubDate).toLocaleDateString('pt-BR', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});

const categoryLabel = normalizeCategoryLabel(post.data.category);
const categoryUrl = `/category/${slugifyCategory(categoryLabel)}/`;
const vtCover = `post-cover-${getPostSlug(post)}`;
---

<Layout
  title={post.data.title}
  description={post.data.meta_description || post.data.description}
  image={post.data.image}
  type="article"
  pubDate={post.data.pubDate}
  updatedDate={post.data.updatedDate}
  author={post.data.author}
  category={post.data.category}
>
  <Header />
  <ReadingProgressBar />

  <main class="pb-16">
    <!-- Capa imersiva -->
    <header class="relative overflow-hidden bg-ink-950 text-white">
      {post.data.image && (
        <div class="absolute inset-0">
          <Image
            src={post.data.image}
            alt={post.data.title}
            width={1600}
            height={900}
            widths={[640, 960, 1280, 1600]}
            sizes="100vw"
            layout="constrained"
            loading="eager"
            fetchpriority="high"
            style={`view-transition-name: ${vtCover}`}
            class="parallax-slow h-full w-full object-cover object-center opacity-70"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-ink-950 via-ink-950/60 to-ink-950/20"></div>
          <div class="absolute inset-0 bg-gradient-to-r from-ink-950/50 to-transparent"></div>
        </div>
      )}

      <div class="relative mx-auto flex min-h-[24rem] max-w-4xl flex-col justify-end px-4 pb-12 pt-28 sm:min-h-[28rem] sm:px-6">
        <nav class="mb-5 flex flex-wrap items-center gap-2 text-[11px] font-bold uppercase tracking-[0.16em]" aria-label="Trilha">
          <a href="/" class="text-white/60 transition-colors hover:text-white">Home</a>
          <span class="text-white/30">/</span>
          <a href={categoryUrl} class="rounded-full bg-brand-600 px-3 py-1 text-white shadow-glow-sm transition-transform hover:scale-105">{categoryLabel}</a>
        </nav>

        <h1 class="font-display text-3xl font-extrabold leading-[1.08] tracking-tight text-balance sm:text-4xl lg:text-[2.9rem]">
          {post.data.title}
        </h1>

        <div class="mt-6 flex flex-wrap items-center gap-x-5 gap-y-2 text-xs font-semibold text-white/70">
          <span class="flex items-center gap-2.5">
            <span class="flex h-8 w-8 items-center justify-center rounded-full bg-brand-600/90 font-display text-[10px] font-extrabold uppercase shadow-glow-sm">
              {post.data.author.split(' ').map((w: string) => w[0]).slice(0, 2).join('')}
            </span>
            {post.data.author}
          </span>
          <span class="text-white/30">•</span>
          <span>{formattedDate}</span>
          <span class="text-white/30">•</span>
          <span class="flex items-center gap-1.5"><Icon name="clock" class="h-3.5 w-3.5" /> {post.data.readingTime || '5 min'} de leitura</span>
        </div>
      </div>
    </header>

    <!-- Corpo do artigo -->
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="relative grid grid-cols-1 gap-10 lg:grid-cols-[3rem_minmax(0,1fr)] xl:grid-cols-[3rem_minmax(0,1fr)_16rem]">

        <!-- Rail de compartilhamento (sticky) -->
        <aside class="order-2 lg:order-1">
          <div class="flex items-center gap-2 lg:sticky lg:top-28 lg:flex-col lg:pt-2">
            <span class="hidden font-display text-[9px] font-extrabold uppercase tracking-[0.2em] text-ink-400 lg:block" style="writing-mode: vertical-rl;">Compartilhar</span>
            <a href={`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(Astro.url.href)}`} target="_blank" rel="noreferrer" aria-label="Compartilhar no Facebook" class="flex h-10 w-10 items-center justify-center rounded-full border border-ink-900/10 text-ink-500 transition-all duration-300 hover:-translate-y-1 hover:border-brand-600 hover:bg-brand-600 hover:text-white dark:border-white/10 dark:text-ink-400">
              <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M13.5 21v-8h2.7l.4-3.2h-3.1V7.7c0-.9.3-1.6 1.7-1.6h1.5V3.2c-.3 0-1.2-.1-2.3-.1-2.3 0-3.9 1.4-3.9 4v2.7H7.8V13h2.7v8h3z"/></svg>
            </a>
            <a href={`https://twitter.com/intent/tweet?url=${encodeURIComponent(Astro.url.href)}&text=${encodeURIComponent(post.data.title)}`} target="_blank" rel="noreferrer" aria-label="Compartilhar no X" class="flex h-10 w-10 items-center justify-center rounded-full border border-ink-900/10 text-ink-500 transition-all duration-300 hover:-translate-y-1 hover:border-ink-900 hover:bg-ink-900 hover:text-white dark:border-white/10 dark:text-ink-400 dark:hover:bg-white dark:hover:text-ink-900 dark:hover:border-white">
              <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M17.8 3h3.1l-6.8 7.8L22 21h-6.3l-4.9-6.4L5.2 21H2.1l7.3-8.3L2 3h6.4l4.4 5.9L17.8 3zm-1.1 16.1h1.7L7.4 4.8H5.6l11.1 14.3z"/></svg>
            </a>
            <a href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(Astro.url.href)}`} target="_blank" rel="noreferrer" aria-label="Compartilhar no LinkedIn" class="flex h-10 w-10 items-center justify-center rounded-full border border-ink-900/10 text-ink-500 transition-all duration-300 hover:-translate-y-1 hover:border-brand-700 hover:bg-brand-700 hover:text-white dark:border-white/10 dark:text-ink-400">
              <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M4.98 3.5C4.98 4.88 3.87 6 2.5 6S0 4.88 0 3.5 1.12 1 2.5 1s2.48 1.12 2.48 2.5zM.24 8.16h4.52V23H.24V8.16zM8.34 8.16h4.33v2.02h.06c.6-1.14 2.08-2.34 4.28-2.34 4.58 0 5.42 3.01 5.42 6.92V23h-4.52v-7.18c0-1.71-.03-3.92-2.39-3.92-2.39 0-2.76 1.86-2.76 3.79V23H8.34V8.16z"/></svg>
            </a>
            <button id="copy-article-link" type="button" aria-label="Copiar link do artigo" class="flex h-10 w-10 cursor-pointer items-center justify-center rounded-full border border-ink-900/10 text-ink-500 transition-all duration-300 hover:-translate-y-1 hover:border-brand-600 hover:bg-brand-600 hover:text-white dark:border-white/10 dark:text-ink-400">
              <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 011.242 7.244l-4.5 4.5a4.5 4.5 0 01-6.364-6.364l1.757-1.757m13.35-.622l1.757-1.757a4.5 4.5 0 00-6.364-6.364l-4.5 4.5a4.5 4.5 0 001.242 7.244"/></svg>
            </button>
          </div>
        </aside>

        <!-- Artigo -->
        <div class="order-1 min-w-0 lg:order-2">
          <div class="mx-auto max-w-3xl pt-10">
            <AdSense
              slot="6543940190"
              format="auto"
              fullWidthResponsive={true}
              class="mb-8 w-full"
              simulatedText="AdSense - Topo do Artigo"
            />

            <article class="prose max-w-none">
              <Content />
            </article>

            <Newsletter />

            <AdSense
              slot="3980100424"
              format="auto"
              fullWidthResponsive={true}
              class="mb-4 mt-10 w-full"
              simulatedText="AdSense - Pós Artigo"
            />

            <LivePixWidget className="mt-4" />
            <GiscusComments />
          </div>
        </div>

        <!-- TOC flutuante com scrollspy (desktop xl) -->
        <aside class="order-3 hidden xl:block">
          <nav id="article-toc" aria-label="Índice do artigo" class="sticky top-28 hidden pt-2">
            <p class="font-display text-[10px] font-extrabold uppercase tracking-[0.24em] text-ink-400 dark:text-ink-500">Neste artigo</p>
            <ol class="mt-4 space-y-1 border-l border-ink-900/[0.08] text-[13px] dark:border-white/[0.08]"></ol>
          </nav>
        </aside>
      </div>
    </div>
  </main>

  <Footer />
</Layout>

<style>
  /* Item ativo do índice, marcado via JS IntersectionObserver */
  #article-toc a {
    display: block;
    padding: 0.375rem 0 0.375rem 1rem;
    margin-left: -1px;
    border-left: 2px solid transparent;
    color: var(--color-ink-500);
    transition: color 0.25s ease, border-color 0.25s ease;
    line-height: 1.4;
  }
  .dark #article-toc a { color: var(--color-ink-400); }
  #article-toc a:hover { color: var(--color-brand-600); }
  .dark #article-toc a:hover { color: var(--color-brand-300); }
  #article-toc a.toc-active {
    color: var(--color-brand-600);
    border-left-color: var(--color-brand-600);
    font-weight: 700;
  }
  .dark #article-toc a.toc-active { color: var(--color-brand-300); border-left-color: var(--color-brand-400); }
</style>

<script is:inline>
  const injectMiddleAd = () => {
    if (localStorage.getItem('dougdesign-ads-consent-v1') !== 'accepted' && localStorage.getItem('dougdesign-consent-v1') !== 'accepted') return;
    const article = document.querySelector('article.prose');
    if (!article) return;

    if (document.getElementById('adsense-mid-article')) return;

    const paragraphs = Array.from(article.querySelectorAll(':scope > p'));
    if (paragraphs.length >= 4) {
      const targetIndex = Math.min(3, paragraphs.length - 2);
      const targetPara = paragraphs[targetIndex];

      const adWrapper = document.createElement('div');
      adWrapper.id = 'adsense-mid-article';
      adWrapper.className = 'rounded-2xl border border-dashed border-ink-300 dark:border-ink-600 p-2 text-center text-[10px] text-ink-400 my-8 w-full';

      adWrapper.innerHTML = `
        <div class="text-[9px] uppercase tracking-widest font-bold mb-1">Publicidade</div>
        <ins class="adsbygoogle"
             style="display:block"
             data-ad-client="ca-pub-5927498436558135"
             data-ad-slot="8098120205"
             data-ad-format="auto"
             data-full-width-responsive="true"></ins>
      `;

      targetPara.after(adWrapper);

      try {
        (window.adsbygoogle = window.adsbygoogle || []).push({});
      } catch (e) {}
    }
  };

  const setupArticleEnhancements = () => {
    const article = document.querySelector('article.prose');
    const toc = document.querySelector('#article-toc');
    const copy = document.querySelector('#copy-article-link');

    if (copy && !copy.dataset.bound) {
      copy.dataset.bound = 'true';
      copy.addEventListener('click', async () => {
        await navigator.clipboard?.writeText(window.location.href);
        copy.classList.add('!bg-brand-600', '!text-white', '!border-brand-600');
        setTimeout(() => copy.classList.remove('!bg-brand-600', '!text-white', '!border-brand-600'), 1600);
      });
    }

    if (!article || !toc || toc.dataset.ready === 'true') return;
    const list = toc.querySelector('ol');
    const headings = Array.from(article.querySelectorAll('h2, h3'));
    if (!list || headings.length < 2) return;

    headings.forEach((heading, index) => {
      const id = heading.id || `secao-${index + 1}`;
      heading.id = id;
      const item = document.createElement('li');
      item.style.paddingLeft = heading.tagName === 'H3' ? '0.75rem' : '0';
      item.innerHTML = `<a href="#${id}">${heading.textContent || ''}</a>`;
      list.appendChild(item);
    });
    toc.classList.remove('hidden');
    toc.dataset.ready = 'true';

    // Scrollspy: destaca a seção visível
    const links = Array.from(list.querySelectorAll('a'));
    const setActive = (id) => {
      links.forEach((link) => {
        link.classList.toggle('toc-active', link.getAttribute('href') === `#${id}`);
      });
    };
    if ('IntersectionObserver' in window) {
      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) setActive(entry.target.id);
        });
      }, { rootMargin: '-15% 0px -70% 0px' });
      headings.forEach((h) => observer.observe(h));
    }
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', () => { injectMiddleAd(); setupArticleEnhancements(); }, { once: true });
  } else {
    injectMiddleAd();
    setupArticleEnhancements();
  }
  document.addEventListener('astro:page-load', () => { injectMiddleAd(); setupArticleEnhancements(); });
</script>
