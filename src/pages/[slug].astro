---
import { render } from 'astro:content';
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Icon from '../components/Icon.astro';
import LivePixWidget from '../components/LivePixWidget.astro';
import { getPostSlug, getPublishedPosts } from '../lib/blog';

export async function getStaticPaths() {
  const posts = await getPublishedPosts();
  return posts.map(post => ({
    params: { slug: getPostSlug(post) },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const formattedDate = new Date(post.data.pubDate).toLocaleDateString('pt-BR', {
  day: 'numeric',
  month: 'short',
  year: 'numeric',
});
---

<Layout 
  title={post.data.title} 
  description={post.data.meta_description || post.data.description}
  image={post.data.image}
  type="article"
  pubDate={post.data.pubDate}
  author={post.data.author}
>
  <!-- Header (Fica sticky/bottom dependendo do dispositivo) -->
  <Header />

  <main class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8 font-sans">
    <!-- Voltar -->
    <a href="/" class="inline-flex items-center gap-1 text-slate-500 hover:text-brand-600 dark:text-zinc-400 dark:hover:text-brand-500 text-xs font-semibold uppercase tracking-wider mb-6 transition-colors font-display">
      <Icon name="chevron-left" class="w-4 h-4" /> Voltar para Home
    </a>

    <!-- Header do Artigo -->
    <header class="mb-8">
      <div class="flex items-center gap-2 text-xs font-bold uppercase tracking-wider text-brand-600 dark:text-brand-500 mb-3 font-display">
        <span>{post.data.category}</span>
        <span class="text-slate-300 dark:text-zinc-700 font-normal">|</span>
        <span class="text-slate-500 dark:text-zinc-400 font-semibold">{post.data.readingTime || '5 min'} de leitura</span>
      </div>
      <h1 class="font-display font-extrabold text-3xl sm:text-4xl lg:text-5xl text-slate-900 dark:text-white leading-tight">
        {post.data.title}
      </h1>
      <div class="flex items-center gap-3 mt-4 text-xs font-semibold text-slate-500 dark:text-zinc-400">
        <span class="text-slate-800 dark:text-zinc-200">{post.data.author}</span>
        <span>•</span>
        <span>Publicado em {formattedDate}</span>
      </div>
    </header>

    <!-- Imagem de Destaque Otimizada e Eager LCP -->
    {post.data.image && (
      <div class="relative w-full h-[300px] sm:h-[400px] lg:h-[480px] rounded-2xl overflow-hidden bg-slate-200 dark:bg-darkbg-900 shadow-md">
        <Image 
          src={post.data.image} 
          alt={post.data.title}
          width={1200}
          height={675}
          loading="eager"
          fetchpriority="high"
          class="w-full h-full object-cover object-center"
        />
      </div>
    )}

    <!-- Conteúdo do Artigo -->
    <article class="prose dark:prose-invert max-w-none mt-8 text-slate-800 dark:text-zinc-200 leading-relaxed font-normal">
      <Content />
    </article>

    <!-- LivePix Sponsor -->
    <LivePixWidget className="mt-12" />

    <!-- Giscus Comentários -->
    <section class="mt-16 pt-8 border-t border-slate-200 dark:border-zinc-800">
      <h2 class="font-display font-bold text-xl text-slate-900 dark:text-white mb-6">Comentários</h2>
      <script src="https://giscus.app/client.js"
              data-repo="dougdesign/blog-comments"
              data-repo-id="R_kgDOH..."
              data-category="Announcements"
              data-category-id="DIC_kwDOH..."
              data-mapping="pathname"
              data-strict="0"
              data-reactions-enabled="1"
              data-emit-metadata="0"
              data-input-position="bottom"
              data-theme="preferred_color_theme"
              data-lang="pt"
              crossorigin="anonymous"
              async>
      </script>
    </section>
  </main>

  <Footer />
</Layout>
