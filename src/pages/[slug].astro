---
import { render } from 'astro:content';
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Icon from '../components/Icon.astro';
import LivePixWidget from '../components/LivePixWidget.astro';
import GiscusComments from '../components/GiscusComments.astro';
import { getPostSlug, getPublishedPosts } from '../lib/blog';
import AdSense from '../components/AdSense.astro';
import Sidebar from '../components/Sidebar.astro';

export async function getStaticPaths() {
  const posts = await getPublishedPosts();
  return posts.map(post => ({
    params: { slug: getPostSlug(post) },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const formattedDate = new Date(post.data.pubDate).toLocaleDateString('pt-BR', {
  day: 'numeric',
  month: 'short',
  year: 'numeric',
});
---

<Layout 
  title={post.data.title} 
  description={post.data.meta_description || post.data.description}
  image={post.data.image}
  type="article"
  pubDate={post.data.pubDate}
  author={post.data.author}
>
  <!-- Header (Fica sticky/bottom dependendo do dispositivo) -->
  <Header />

  <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 font-sans">
    <!-- Voltar -->
    <a href="/" class="inline-flex items-center gap-1 text-slate-500 hover:text-brand-600 dark:text-zinc-400 dark:hover:text-brand-500 text-xs font-semibold uppercase tracking-wider mb-6 transition-colors font-display">
      <Icon name="chevron-left" class="w-4 h-4" /> Voltar para Home
    </a>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      <!-- Main Content Column -->
      <div class="lg:col-span-2">
        <!-- Header do Artigo -->
        <header class="mb-8">
          <div class="flex items-center gap-2 text-xs font-bold uppercase tracking-wider text-brand-600 dark:text-brand-500 mb-3 font-display">
            <span>{post.data.category}</span>
            <span class="text-slate-300 dark:text-zinc-700 font-normal">|</span>
            <span class="text-slate-500 dark:text-zinc-400 font-semibold">{post.data.readingTime || '5 min'} de leitura</span>
          </div>
          <h1 class="font-display font-extrabold text-3xl sm:text-4xl lg:text-5xl text-slate-900 dark:text-white leading-tight">
            {post.data.title}
          </h1>
          <div class="flex items-center gap-3 mt-4 text-xs font-semibold text-slate-500 dark:text-zinc-400">
            <span class="text-slate-800 dark:text-zinc-200">{post.data.author}</span>
            <span>•</span>
            <span>Publicado em {formattedDate}</span>
          </div>
        </header>

        <!-- Imagem de Destaque Otimizada e Eager LCP -->
        {post.data.image && (
          <div class="relative w-full h-[300px] sm:h-[400px] lg:h-[480px] rounded-2xl overflow-hidden bg-slate-200 dark:bg-darkbg-900 shadow-md">
            <Image 
              src={post.data.image} 
              alt={post.data.title}
              width={1200}
              height={675}
              widths={[480, 720, 960, 1200]}
              sizes="(max-width: 640px) 100vw, (max-width: 1024px) 90vw, 1200px"
              layout="constrained"
              loading="eager"
              fetchpriority="high"
              class="w-full h-full object-cover object-center"
            />
          </div>
        )}

        <!-- ADSENSE: Após imagem de destaque, acima da dobra do artigo -->
        <AdSense
          slot="6543940190"
          format="auto"
          fullWidthResponsive={true}
          class="w-full my-6"
          simulatedText="AdSense - Topo do Artigo"
        />
        
        <article class="prose dark:prose-invert max-w-none mt-8 text-slate-800 dark:text-zinc-200 leading-relaxed font-normal">
          <Content />
        </article>

        <!-- ADSENSE: Após artigo, antes do LivePix - posição de alta intenção -->
        <AdSense
          slot="3980100424"
          format="auto"
          fullWidthResponsive={true}
          class="w-full mt-10 mb-4"
          simulatedText="AdSense - Pós Artigo"
        />

        <!-- LivePix Sponsor -->
        <LivePixWidget className="mt-4" />

        <GiscusComments />
      </div>

      <!-- Sidebar Column -->
      <aside class="lg:col-span-1">
        <Sidebar />
      </aside>
    </div>
  </main>

  <Footer />
</Layout>

<script is:inline>
  const injectMiddleAd = () => {
    const article = document.querySelector('article.prose');
    if (!article) return;
    
    // Check if we already injected the ad to prevent duplicates on view transition
    if (document.getElementById('adsense-mid-article')) return;
    
    const paragraphs = Array.from(article.querySelectorAll(':scope > p'));
    if (paragraphs.length >= 4) {
      // Target paragraph is approximately in the middle (usually after paragraph 3 or 4)
      const targetIndex = Math.min(3, paragraphs.length - 2);
      const targetPara = paragraphs[targetIndex];
      
      const adWrapper = document.createElement('div');
      adWrapper.id = 'adsense-mid-article';
      adWrapper.className = 'bg-white dark:bg-darkbg-900 border border-dashed border-slate-300 dark:border-slate-800 p-2 text-center text-[10px] text-slate-400 dark:text-zinc-500 rounded-lg my-8 w-full';
      
      adWrapper.innerHTML = `
        <div class="text-[9px] uppercase tracking-widest font-bold mb-1">Publicidade</div>
        <ins class="adsbygoogle"
             style="display:block"
             data-ad-client="ca-pub-5927498436558135"
             data-ad-slot="8098120205"
             data-ad-format="auto"
             data-full-width-responsive="true"></ins>
        <div class="mt-1 text-[8px] uppercase tracking-wider text-slate-400 dark:text-zinc-500 bg-slate-50 dark:bg-darkbg-950/30 py-1.5 rounded font-semibold">
          Google AdSense - Artigo Meio (Slot: 8098120205)
        </div>
      `;
      
      targetPara.after(adWrapper);
      
      // Push the ad to AdSense initialization
      try {
        (window.adsbygoogle = window.adsbygoogle || []).push({});
      } catch (e) {
        // Silent catch in case adsbygoogle is not loaded yet or blocked by blocker
      }
    }
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', injectMiddleAd);
  } else {
    injectMiddleAd();
  }
  document.addEventListener('astro:page-load', injectMiddleAd);
</script>
